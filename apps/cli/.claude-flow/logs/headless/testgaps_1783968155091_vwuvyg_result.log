        "code": "func TestUpdate_StatusMsgAppendsLineAndRefreshesOnlyWhenHighlighted(t *testing.T) {\n\tm := newTestModel()\n\tm.runOrder = []string{\"provider-a\", \"provider-b\"}\n\tm.runCursor = 0\n\tm.statuses[\"provider-a\"] = &providerStatus{}\n\tm.statuses[\"provider-b\"] = &providerStatus{}\n\n\tm.Update(statusMsg{provider: \"provider-b\", line: \"hello\"})\n\tif len(m.statuses[\"provider-b\"].lines) != 1 {\n\t\tt.Fatal(\"line not appended for non-highlighted provider\")\n\t}\n\tif m.vp.View() != \"\" && strings.Contains(m.vp.View(), \"hello\") {\n\t\tt.Error(\"viewport should not refresh for a non-highlighted provider\")\n\t}\n}\n\nfunc TestUpdate_DoneMsg_ErrorPathSetsErrorStateAndAppendsMessage(t *testing.T) {\n\tm := newTestModel()\n\tm.pending = 1\n\tm.statuses[\"p\"] = &providerStatus{state: stateRunning}\n\tm.Update(doneMsg{provider: \"p\", err: errors.New(\"boom\")})\n\tst := m.statuses[\"p\"]\n\tif st.state != stateError {\n\t\tt.Error(\"expected stateError\")\n\t}\n\tif m.pending != 0 {\n\t\tt.Error(\"pending should decrement on done, error or not\")\n\t}\n\tif !strings.Contains(st.lines[len(st.lines)-1], \"boom\") {\n\t\tt.Error(\"error message not appended to lines\")\n\t}\n}\n\nfunc TestUpdate_DoneMsg_SuccessPath(t *testing.T) {\n\tm := newTestModel()\n\tm.pending = 1\n\tm.statuses[\"p\"] = &providerStatus{state: stateRunning}\n\tm.Update(doneMsg{provider: \"p\", err: nil})\n\tif m.statuses[\"p\"].state != stateDone {\n\t\tt.Error(\"expected stateDone\")\n\t}\n}\n\nfunc TestUpdate_WindowSizeMsg_RecomputesLayoutAndViewport(t *testing.T) {\n\tm := newTestModel()\n\tm.Update(tea.WindowSizeMsg{Width: 100, Height: 40})\n\tif m.width != 100 || m.height != 40 {\n\t\tt.Error(\"dimensions not stored\")\n\t}\n}"
