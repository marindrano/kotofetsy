ackage main\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n)\n\nfunc writeFakeCrawler(t *testing.T, dir, script string) {\n\tt.Helper()\n\tif err := os.WriteFile(filepath.Join(dir, \"main.py\"), []byte(script), 0755); err != nil {\n\t\tt.Fatal(err)\n\t}\n}\n\nfunc TestRunCrawler_StreamsStdoutLines(t *testing.T) {\n\t// Requires \"uv\" on PATH in CI, or refactor runCrawler to accept an\n\t// exec.Cmd factory so a fake command can be substituted. Skeleton\n\t// assumes the latter (recommended seam):\n\t//\n\t//   func runCrawler(name string, limit int, crawlerDir string,\n\t//       newCmd func(name, dir string, limit int) *exec.Cmd, onLine func(string)) error\n\tt.Skip(\"needs command-injection seam; see testability note\")\n}\n\nfunc TestRunCrawler_FoldsStderrIntoStdout(t *testing.T) {\n\tt.Skip(\"needs command-injection seam\")\n}\n\nfunc TestRunCrawler_NonZeroExitReturnsError(t *testing.T) {\n\tt.Skip(\"needs command-injection seam\")\n}\n\nfunc TestRunCrawler_BinaryNotFound(t *testing.T) {\n\terr := runCrawler(\"nonexistent-provider\", 1, t.TempDir(), func(string) {})\n\tif err == nil {\n\t\tt.Fatal(\"expected error when crawler binary/dir is invalid\")\n\t}\n}\n\nfunc TestRunCrawler_LineLongerThanScannerBuffer(t *testing.T) {\n\t// A single stdout line > bufio.MaxScanTokenSize (64KB) should either\n\t// be handled gracefully or the error should be surfaced — today it\n\t// is silently dropped. Regression test once fixed.\n\tt.Skip(\"known gap: oversized line truncates output silently\")\n}\n```\n\n**`runHeadless`**\n- Splits `providersFlag` on `,` — no trimming of whitespace (`\"a, b\"` → `[\" b\"]` with a leading space that never matches a provider). Untested edge case.\n- Concurrent execution: verify all providers run even if one errors (goroutine independence).\n- Empty `names` slice (e.g. `--providers \"\"`) — currently produces `[\"\"]` via `strings.Split`, which then gets passed to `runCrawler` as a provider name; no validation against the known `providers` list at all, headless or interactive.\n\n```go\nfunc TestRunHeadless_CommaSplitDoesNotTrimWhitespace(t *testing.T) {\n\tnames := strings.Split(\"midi-madagasikara, lexpress-mg\", \",\")\n\tif names[1] == \"lexpress-mg\" {\n\t\tt.Fatalf(\"expected untrimmed leading space bug to reproduce, got %q\", names[1])\n\t}\n\t// documents current behavior; once main.go trims, flip this assertion\n}\n\nfunc TestRunHeadless_UnknownProviderNameNotValidated(t *testing.T) {\n\t// runHeadless(providersFlag split) never checks names against `providers`;\n\t// an unknown/misspelled name silently fails at the Python layer instead\n\t// of failing fast in the CLI.\n\tt.Skip(\"missing input validation at the providers flag boundary\")\n}\n```\n\n---\n\n## 2. `tui.go`\n\n### Pure functions — easy, high-value, currently untested\n\n**`countSelected`**\n```go\nfunc TestCountSelected(t *testing.T) {\n\tcases := []struct {\n\t\tname     string\n\t\tselected map[int]bool\n\t\twant     int\n\t}{\n\t\t{\"empty\", map[int]bool{}, 0},\n\t\t{\"none true\", map[int]bool{0: false, 1: false}, 0},\n\t\t{\"some true\", map[int]bool{0: true, 1: false, 2: true}, 2},\n\t\t{\"all true\", map[int]bool{0: true, 1: true}, 2},\n\t}\n\tfor _, c := range cases {\n\t\tt.Run(c.name, func(t *testing.T) {\n\t\t\tm := &model{selected: c.selected}\n\t\t\tif got := m.countSelected(); got != c.want {\n\t\t\t\tt.Errorf(\"got %d, want %d\", got, c.want)\n\t\t\t}\n\t\t})\n\t}\n}\n```\n\n**`articlesSaved`**\n```go\nfunc TestArticlesSaved(t *testing.T) {\n\tcases := []struct {\n\t\tname  string\n\t\tlines []string\n\t\twant  int\n\t}{\n\t\t{\"empty\", nil, 0},\n\t\t{\"no matches\", []string{\"info: starting\", \"done\"}, 0},\n\t\t{\"some matches\", []string{\"  - 'title one' (2026-01-01)\", \"info\", \"  - 'title two' (2026-01-02)\"}, 2},\n\t\t{\"prefix must be exact\", []string{\"- 'not indented'\"}, 0}, // documents the strict \"  - \" prefix requirement\n\t}\n\tfor _, c := range cases {\n\t\tt.