\n\t}{\n\t\t{\"shorter than n\", \"abc\", 10, \"abc\"},\n\t\t{\"exact length\", \"abc\", 3, \"abc\"},\n\t\t{\"n zero\", \"abc\", 0, \"abc\"[:0]},\n\t\t{\"n one\", \"abcdef\", 1, \"a\"},\n\t\t{\"needs ellipsis\", \"abcdefgh\", 5, \"abcdâ€¦\"},\n\t\t{\"multibyte input\", \"madagascar-tribĂĽne\", 12, \"\"}, // TODO: define expected behavior;\n\t\t// currently byte-slices and can corrupt UTF-8 â€” pin down desired semantics\n\t\t// (rune-safe truncation) before asserting an exact want value.\n\t}\n\tfor _, c := range cases {\n\t\tt.Run(c.name, func(t *testing.T) {\n\t\t\tgot := truncate(c.s, c.n)\n\t\t\tt.Logf(\"truncate(%q, %d) = %q\", c.s, c.n, got)\n\t\t\t// assert once expected semantics are decided\n\t\t})\n\t}\n}\n\nfunc TestUpdate_StatusMsgForUnknownProvider_ShouldNotPanic(t *testing.T) {\n\tm := newModel(10, \".\")\n\tdefer func() {\n\t\tif r := recover(); r != nil {\n\t\t\tt.Fatalf(\"Update panicked on unregistered provider: %v\", r)\n\t\t}\n\t}()\n\tm.Update(statusMsg{provider: \"ghost\", line: \"x\"})\n}\n\nfunc TestUpdate_DoneMsgDecrementsPending(t *testing.T) {\n\tm := newModel(10, \".\")\n\tm.statuses[\"p1\"] = &providerStatus{state: stateRunning}\n\tm.pending = 1\n\tm.Update(doneMsg{provider: \"p1\"})\n\tif m.pending != 0 {\n\t\tt.Errorf(\"pending = %d, want 0\", m.pending)\n\t}\n\tif m.statuses[\"p1\"].state != stateDone {\n\t\tt.Errorf(\"state = %v, want stateDone\", m.statuses[\"p1\"].state)\n\t}\n}\n\nfunc TestUpdate_DoneMsgWithError_SetsErrorStateAndAppendsLine(t *testing.T) {\n\tm := newModel(10, \".\")\n\tm.statuses[\"p1\"] = &providerStatus{state: stateRunning}\n\tm.pending = 1\n\tm.Update(doneMsg{provider: \"p1\", err: errBoom})\n\tst := m.statuses[\"p1\"]\n\tif st.state != stateError {\n\t\tt.Errorf(\"state = %v, want stateError\", st.state)\n\t}\n\tif !strings.Contains(st.lines[len(st.lines)-1], \"error:\") {\n\t\tt.Errorf(\"expected error line appended, got %v\", st.lines)\n\t}\n}\n\nfunc TestHandleKey_Picking_CursorBounds(t *testing.T) {\n\tm := newModel(10, \".\")\n\tm.screen = screenPicking\n\tm.handleKey(tea.KeyMsg{Type: tea.KeyUp}) // at 0, should stay 0\n\tif m.cursor != 0 {\n\t\tt.Errorf(\"cursor = %d, want 0\", m.cursor)\n\t}\n\tm.cursor = len(providers) - 1\n\tm.handleKey(tea.KeyMsg{Type: tea.KeyDown})\n\tif m.cursor != len(providers)-1 {\n\t\tt.Errorf(\"cursor = %d, want %d (clamped)\", m.cursor, len(providers)-1)\n\t}\n}\n\nfunc TestHandleKey_Picking_EnterWithNoneSelected_SelectsAll(t *testing.T) {\n\tm := newModel(10, \".\")\n\tm.screen = screenPicking\n\tm.handleKey(tea.KeyMsg{Type: tea.KeyEnter})\n\tif m.countSelected() != len(providers) {\n\t\tt.Errorf(\"expected all providers selected, got %d\", m.countSelected())\n\t}\n}\n\nfunc TestHandleKey_Limit_InvalidInput_NoFeedback(t *testing.T) {\n\t// Documents current gap: invalid input is silently dropped with no\n\t// error surfaced to the user. Once feedback is added, replace this\n\t// assertion with a check on the new error field/message.\n\tm := newModel(10, \".\")\n\tm.screen = screenLimit\n\tm.limitInput.SetValue(\"not-a-number\")\n\tm.handleKey(tea.KeyMsg{Type: tea.KeyEnter})\n\tif m.screen != screenLimit {\n\t\tt.Errorf(\"screen advanced despite invalid input\")\n\t}\n}\n\nfunc TestHandleKey_Limit_NegativeRejected_ZeroAccepted(t *testing.T) {\n\tm := newModel(10, \".\")\n\tm.screen = screenLimit\n\tm.limitInput.SetValue(\"-1\")\n\tm.handleKey(tea.KeyMsg{Type: tea.KeyEnter})\n\tif m.screen != screenLimit {\n\t\tt.Errorf(\"negative limit should not advance screen\")\n\t}\n\n\tm.limitInput.SetValue(\"0\")\n\tm.handleKey(tea.KeyMsg{Type: tea.KeyEnter})\n\tif m.limit != 0 {\n\t\tt.Errorf(\"limit = %d, want 0 (unlimited)\", m.limit)\n\t}\n}\n\nfunc TestView_AllScreens_DoNotPanicAndNonEmpty(t *testing.T) {\n\tm := newModel(10, \".\")\n\tm.width, m.height = 100, 40\n\tfor _, s := range []screen{screenPicking, screenLimit, screenRunning} {\n\t\tm.screen = s\n\t\tm.vp.Width, m.vp.Height = m.layout()\n\t\tout := m.View()\n\t\tif out == \"\" {\n\t\t\tt.Errorf(\"View() empty for screen %v\", s)\n\t\t}\n\t}\n}\n\nvar errBoom = &testError{\"boom\"}\n\ntype testError struct{ msg string }\n\nfunc (e *testError) Error() string { return e.msg }\n```\n\n**Integration test skeleton** (`integration_test.go`, could gate behind a build tag if it needs `uv`):\n\n```go\n//go:build integration\n\npackage main\n\nimport \"testing\"\n\nfunc TestHeadlessRun_AgainstRealCrawler(t *testing.T) {\n\t// Run: go run . --headless --providers=<one fast provider> --limit=1\n\t// against the real apps/crawler, asserting exit code 0 and that\n\t// stdout contains at least one \"  - \" line â€” pins the contract that\n\t// tui.go's articlesSaved() depends on.\n}\n```\n\n",
