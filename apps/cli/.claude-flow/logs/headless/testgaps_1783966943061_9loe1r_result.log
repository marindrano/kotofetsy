        "content": "\n| Function | File:Line | Gap |\n|---|---|---|\n| `articlesSaved(lines []string) int` | tui.go:361 | No coverage of prefix-matching logic |\n| `truncate(s string, n int) string` | tui.go:370 | No coverage; **byte-slicing on `len(s)` breaks on multi-byte UTF-8**, and `n<0` with non-empty `s` panics (`s[:n]` with negative index) |\n| `(m *model) layout() (int, int)` | tui.go:222 | Clamping guards (`vpW<10`, `vpH<3`) never exercised |\n| `(m *model) highlighted() string` | tui.go:236 | Out-of-range guard (`runCursor<0` or `>=len`) never exercised |\n| `(m *model) countSelected() int` | tui.go:296 | No coverage |\n| `newModel(...)` | tui.go:73 | No coverage of initial state |\n\n```go\n// tui_test.go\npackage main\n\nimport \"testing\"\n\nfunc TestArticlesSaved(t *testing.T) {\n\tcases := []struct {\n\t\tname  string\n\t\tlines []string\n\t\twant  int\n\t}{\n\t\t{\"empty\", nil, 0},\n\t\t{\"no matches\", []string{\"fetching...\", \"done\"}, 0},\n\t\t{\"single match\", []string{\"  - 'Title' (2026-07-01)\"}, 1},\n\t\t{\"mixed lines\", []string{\"log line\", \"  - 'A'\", \"log\", \"  - 'B'\"}, 2},\n\t\t{\"prefix-only no trailing content\", []string{\"  - \"}, 1},\n\t\t{\"near-miss indentation not counted\", []string{\" - 'A'\"}, 0}, // single leading space\n\t}\n\tfor _, tc := range cases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tif got := articlesSaved(tc.lines); got != tc.want {\n\t\t\t\tt.Errorf(\"got %d, want %d\", got, tc.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTruncate(t *testing.T) {\n\tcases := []struct {\n\t\tname string\n\t\ts    string\n\t\tn    int\n\t\twant string\n\t}{\n\t\t{\"shorter than n\", \"abc\", 10, \"abc\"},\n\t\t{\"equal to n\", \"abcde\", 5, \"abcde\"},\n\t\t{\"longer, truncates with ellipsis\", \"abcdefgh\", 5, \"abcd…\"},\n\t\t{\"n=1\", \"abcdef\", 1, \"a\"},\n\t\t{\"n=0 on non-empty string\", \"abcdef\", 0, \"\"}, // s[:0]\n\t\t{\"multi-byte rune truncated mid-codepoint\", \"café\", 3, \"\"},\n\t\t// ^ current impl uses len() (bytes) not rune count; 'é' is 2 bytes,\n\t\t//   so this documents/pins the known non-ASCII truncation bug.\n\t}\n\tfor _, tc := range cases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tgot := truncate(tc.s, tc.n)\n\t\t\tif got != tc.want {\n\t\t\t\tt.Errorf(\"truncate(%q, %d) = %q, want %q\", tc.s, tc.n, got, tc.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTruncateNegativeNPanics(t *testing.T) {\n\t// documents a latent bug: truncate(s, negative) panics via negative slice\n\t// index when s is non-empty. Currently unreachable (all call sites pass\n\t// positive literals) but worth guarding if n ever becomes dynamic.\n\tdefer func() {\n\t\tif r := recover(); r == nil {\n\t\t\tt.Error(\"expected panic on negative n, got none — bug may have been fixed, update this test\")\n\t\t}\n\t}()\n\ttruncate(\"abc\", -1)\n}\n\nfunc TestModelLayout(t *testing.T) {\n\tcases := []struct {\n\t\tname       string\n\t\twidth      int\n\t\theight     int\n\t\twantW      int\n\t\twantH      int\n\t}{\n\t\t{\"normal size\", 100, 40, 100 - sidenavWidth - 4, 40 - 6},\n\t\t{\"tiny width clamps to 10\", 5, 40, 10, 34},\n\t\t{\"tiny height clamps to 3\", 100, 2, 68, 3},\n\t\t{\"zero size before first WindowSizeMsg\", 0, 0, 10, 3},\n\t}\n\tfor _, tc := range cases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tm := newModel(10, \"../crawler\")\n\t\t\tm.width, m.height = tc.width, tc.height\n\t\t\tgotW, gotH := m.layout()\n\t\t\tif gotW != tc.wantW || gotH != tc.wantH {\n\t\t\t\tt.Errorf(\"layout() = (%d,%d), want (%d,%d)\", gotW, gotH, tc.wantW, tc.wantH)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestModelHighlighted(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tif got := m.highlighted(); got != \"\" {\n\t\tt.Errorf(\"empty runOrder: got %q, want \\\"\\\"\", got)\n\t}\n\tm.runOrder = []string{\"a\", \"b\"}\n\tm.runCursor = 1\n\tif got := m.highlighted(); got != \"b\" {\n\t\tt.Errorf(\"got %q, want b\", got)\n\t}\n\tm.runCursor = -1\n\tif got := m.highlighted(); got != \"\" {\n\t\tt.Errorf(\"negative cursor: got %q, want \\\"\\\"\", got)\n\t}\n\tm.runCursor = len(m.runOrder)\n\tif got := m.highlighted(); got != \"\" {\n\t\tt.Errorf(\"cursor==len: got %q, want \\\"\\\"\", got)\n\t}\n}\n\nfunc TestModelCountSelected(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tif m.countSelected() != 0 {\n\t\tt.Error(\"expected 0 on fresh model\")\n\t}\n\tm.selected[0] = true\n\tm.selected[1] = false\n\tm.selected[2] = true\n\tif got := m.countSelected(); got != 2 {\n\t\tt.Errorf(\"got %d, want 2\", got)\n\t}\n}\n```\n\n",
        "level": 3
      },
      {
        "title": "2. `handleKey` — the most complex untested logic (screen state machine)",
        "content": "\nNo test exercises cursor bounds, selection toggling, the \"select-all-if-none-chosen\" fallback on `enter`, `esc` back-navigation, or the **quit-blocked-while-running** rule.\n\n```go\nfunc TestHandleKeyPicking(t *testing.T) {\n\tt.Run(\"cursor clamps at bounds\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.handleKey(keyMsg(\"up\")) // already at 0, should stay 0\n\t\tif m.cursor != 0 {\n\t\t\tt.Errorf(\"cursor = %d, want 0\", m.cursor)\n\t\t}\n\t\tm.cursor = len(providers) - 1\n\t\tm.handleKey(keyMsg(\"down\"))\n\t\tif m.cursor != len(providers)-1 {\n\t\t\tt.Errorf(\"cursor = %d, want %d\", m.cursor, len(providers)-1)\n\t\t}\n\t})\n\n\tt.Run(\"space toggles selection\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.handleKey(keyMsg(\" \"))\n\t\tif !m.selected[0] {\n\t\t\tt.Error(\"expected index 0 selected\")\n\t\t}\n\t\tm.handleKey(keyMsg(\" \"))\n\t\tif m.selected[0] {\n\t\t\tt.Error(\"expected index 0 deselected\")\n\t\t}\n\t})\n\n\tt.Run(\"'a' selects all\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.handleKey(keyMsg(\"a\"))\n\t\tif m.countSelected() != len(providers) {\n\t\t\tt.Errorf(\"countSelected = %d, want %d\", m.countSelected(), len(providers))\n\t\t}\n\t})\n\n\tt.Run(\"enter with none selected defaults to all, advances screen\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.handleKey(keyMsg(\"enter\"))\n\t\tif m.countSelected() != len(providers) {\n\t\t\tt.Error(\"expected implicit select-all on enter with none picked\")\n\t\t}\n\t\tif m.screen != screenLimit {\n\t\t\tt.Errorf(\"screen = %v, want screenLimit\", m.screen)\n\t\t}\n\t})\n\n\tt.Run(\"enter with explicit selection preserves it\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.selected[0] = true\n\t\tm.handleKey(keyMsg(\"enter\"))\n\t\tif m.countSelected() != 1 {\n\t\t\tt.Errorf(\"countSelected = %d, want 1\", m.countSelected())\n\t\t}\n\t})\n}\n\nfunc TestHandleKeyLimit(t *testing.T) {\n\tt.Run(\"esc returns to picking\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.screen = screenLimit\n\t\tm.handleKey(keyMsg(\"esc\"))\n\t\tif m.screen != screenPicking {\n\t\t\tt.Errorf(\"screen = %v, want screenPicking\", m.screen)\n\t\t}\n\t})\n\n\tt.Run(\"enter with invalid (non-numeric) input is a no-op\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.screen = screenLimit\n\t\tm.limitInput.SetValue(\"not-a-number\")\n\t\tm.handleKey(keyMsg(\"enter\"))\n\t\tif m.screen != screenLimit {\n\t\t\tt.Error(\"expected to stay on screenLimit for invalid input\")\n\t\t}\n\t})\n\n\tt.Run(\"enter with negative limit is a no-op\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.screen = screenLimit\n\t\tm.limitInput.SetValue(\"-5\")\n\t\tm.handleKey(keyMsg(\"enter\"))\n\t\tif m.screen != screenLimit {\n\t\t\tt.Error(\"expected to reject negative limit\")\n\t\t}\n\t})\n\n\tt.Run(\"enter with 0 (unlimited) is accepted\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.screen = screenLimit\n\t\tm.program = fakeProgram() // needed: startRun spawns goroutines calling m.program.Send\n\t\tm.limitInput.SetValue(\"0\")\n\t\tm.handleKey(keyMsg(\"enter\"))\n\t\tif m.limit != 0 || m.screen != screenRunning {\n\t\t\tt.Errorf(\"limit=%d screen=%v, want 0/screenRunning\", m.limit, m.screen)\n\t\t}\n\t})\n}\n\nfunc TestHandleKeyQuit(t *testing.T) {\n\tt.Run(\"q quits when not running\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\t_, cmd := m.handleKey(keyMsg(\"q\"))\n\t\tif cmd == nil {\n\t\t\tt.Error(\"expected tea.Quit cmd\")\n\t\t}\n\t})\n\n\tt.Run(\"q is blocked while providers still pending\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.screen = screenRunning\n\t\tm.pending = 2\n\t\t_, cmd := m.handleKey(keyMsg(\"q\"))\n\t\tif cmd != nil {\n\t\t\tt.Error(\"expected quit to be blocked while pending > 0\")\n\t\t}\n\t})\n\n\tt.Run(\"q quits once all providers finish\", func(t *testing.T) {\n\t\tm := newModel(10, \"../crawler\")\n\t\tm.screen = screenRunning\n\t\tm.pending = 0\n\t\t_, cmd := m.handleKey(keyMsg(\"q\"))\n\t\tif cmd == nil {\n\t\t\tt.Error(\"expected tea.Quit cmd once pending==0\")\n\t\t}\n\t})\n}\n\n// keyMsg is a test helper — tea.KeyMsg has no public constructor for named\n// keys, so build via tea.KeyMsg{Type: ...} for special keys or Runes for\n// literal chars in the actual implementation.\nfunc keyMsg(s string) tea.KeyMsg { /* ... */ return tea.KeyMsg{} }\n```\n\n",
        "level": 3
      },
      {
        "title": "3. `Update()` — message-handling edge cases, including a **nil-pointer panic gap**",
        "content": "\n`statusMsg`/`doneMsg` handlers do `st := m.statuses[msg.provider]; st.state = ...` with no nil-check. This only stays safe because `startRun` is the sole producer and always seeds `m.statuses[name]` first. There's no test proving that invariant, and no defensive test for what happens if it's ever violated (e.g. a future refactor sends a message for a provider not in the map).\n\n```go\nfunc TestUpdateStatusMsgKnownProvider(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tm.statuses[\"p1\"] = &providerStatus{state: stateIdle}\n\tm.runOrder = []string{\"p1\"}\n\tm.Update(statusMsg{provider: \"p1\", line: \"hello\"})\n\tif m.statuses[\"p1\"].state != stateRunning {\n\t\tt.Error(\"expected state -> running\")\n\t}\n\tif len(m.statuses[\"p1\"].lines) != 1 {\n\t\tt.Error(\"expected line appended\")\n\t}\n}\n\nfunc TestUpdateDoneMsgSuccessAndError(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tm.statuses[\"p1\"] = &providerStatus{state: stateRunning}\n\tm.pending = 1\n\tm.Update(doneMsg{provider: \"p1\", err: nil})\n\tif m.statuses[\"p1\"].state != stateDone || m.pending != 0 {\n\t\tt.Errorf(\"state=%v pending=%d, want done/0\", m.statuses[\"p1\"].state, m.pending)\n\t}\n\n\tm2 := newModel(10, \"../crawler\")\n\tm2.statuses[\"p2\"] = &providerStatus{state: stateRunning}\n\tm2.pending = 1\n\tm2.Update(doneMsg{provider: \"p2\", err: errors.New(\"boom\")})\n\tif m2.statuses[\"p2\"].state != stateError {\n\t\tt.Error(\"expected state -> error\")\n\t}\n\tif len(m2.statuses[\"p2\"].lines) == 0 || !strings.Contains(m2.statuses[\"p2\"].lines[0], \"boom\") {\n\t\tt.Error(\"expected error message appended to lines\")\n\t}\n}\n\n// Known gap: statusMsg/doneMsg for a provider absent from m.statuses will\n// nil-deref panic (tui.go:108, :117). No production code path currently\n// triggers this, but there's no regression test guarding the invariant that\n// startRun() always seeds m.statuses before any goroutine can emit a message.\n// Recommend either (a) a defensive nil-check + ignore-unknown-provider in\n// Update, or (b) a table test asserting the invariant holds across all\n// startRun() call sites if the message-producer surface grows.\n```\n\n",
        "level": 3
      },
      {
        "title": "4. `startRun` / provider-selection → run-order mapping",
        "content": "\nUntested: selected indices map to `providers` in original slice order (not selection order), `pending` count matches selected count, `statuses` map seeded with `stateIdle` for every selected provider only.\n\n```go\nfunc TestStartRunBuildsOrderAndState(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tm.program = fakeProgram() // required — startRun's goroutines call m.program.Send\n\tm.selected[2] = true\n\tm.selected[0] = true\n\tm.startRun()\n\n\t// order should follow `providers` slice order, not selection order\n\twant := []string{providers[0], providers[2]}\n\tif !reflect.DeepEqual(m.runOrder, want) {\n\t\tt.Errorf(\"runOrder = %v, want %v\", m.runOrder, want)\n\t}\n\tif m.pending != 2 {\n\t\tt.Errorf(\"pending = %d, want 2\", m.pending)\n\t}\n\tfor _, name := range want {\n\t\tif m.statuses[name] == nil || m.statuses[name].state != stateIdle {\n\t\t\tt.Errorf(\"expected %s seeded idle\", name)\n\t\t}\n\t}\n\tm.waitForGoroutines() // test-only hook, or inject a fake runCrawler\n}\n```\n\n**Structural gap**: `startRun` currently calls the package-level `runCrawler` directly and spawns real goroutines that shell out to `uv run main.py`. To unit-test `startRun`'s state-management logic without launching real subprocesses, `runCrawler` needs to be injectable (e.g. a `crawlerFn func(name string, limit int, dir string, onLine func(string)) error` field on `model`, defaulted to the real `runCrawler` in `newModel` and swapped for a fake in tests). Same applies to `runHeadless` in main.go.\n\n",
        "level": 3
      },
      {
        "title": "5. `runCrawler` / `runHeadless` — no unit or integration coverage at all",
        "content": "\nThese are the two functions with real external side effects (subprocess exec) and currently **cannot be unit tested** without either refactoring or a filesystem fixture, since `exec.Command(\"uv\", \"run\", \"main.py\", ...)` is hardcoded.\n\n```go\n// main_test.go\n\n// TestRunCrawlerStreamsStdout uses a fake crawlerDir containing a minimal\n// script standing in for `uv run main.py`, to prove line-by-line streaming\n// and stdout/stderr folding without depending on the real Python crawler.\nfunc TestRunCrawlerStreamsStdoutLineByLine(t *testing.T) {\n\t// Requires either:\n\t//  (a) refactoring runCrawler to accept an exec.Cmd factory (preferred —\n\t//      makes this fully unit-testable with a stub), or\n\t//  (b) writing a temp dir with a fake `main.py` (or swapping `uv` for a\n\t//      test binary via PATH manipulation) as a real subprocess integration test.\n\tt.Skip(\"gap: runCrawler has no seam for injecting a fake subprocess\")\n}\n\nfunc TestRunCrawlerPropagatesNonZeroExit(t *testing.T) {\n\t// Gap: cmd.Wait() error path (non-zero exit code) is never asserted.\n\tt.Skip(\"gap: needs subprocess seam, see above\")\n}\n\nfunc TestRunCrawlerFoldsStderrIntoSameStream(t *testing.T) {\n\t// Gap: cmd.Stderr = cmd.Stdout behavior (scrapling logs on stderr) is\n\t// asserted only by comment, never by test.\n\tt.Skip(\"gap: needs subprocess seam, see above\")\n}\n\nfunc TestRunHeadlessAggregatesAcrossProviders(t *testing.T) {\n\t// Gap: concurrent fan-out via sync.WaitGroup, per-provider \"[name] line\"\n\t// / \"[name] error: ...\" print format — no coverage. Needs runCrawler\n\t// injected as a func field/param to avoid real subprocess calls.\n\tt.Skip(\"gap: runHeadless calls package-level runCrawler directly, not injectable\")\n}\n```\n\n",
        "level": 3
      },
      {
        "title": "6. `main()` — flag parsing and dispatch branch, untested",
        "content": "\n```go\nfunc TestMainFlagDefaults(t *testing.T) {\n\t// Gap: no test proves --limit defaults to 10, --crawler-dir defaults to\n\t// \"../crawler\", --providers defaults to \"all\", or that --headless\n\t// correctly short-circuits to runHeadless vs. launching the TUI.\n\t// main() as written is not decomposed for testing — recommend extracting\n\t// flag-parsing + dispatch into a `run(args []string) error` function that\n\t// main() calls with os.Args[1:], enabling this test without a real process spawn.\n\tt.Skip(\"gap: main() not decomposed into a testable run(args) function\")\n}\n```\n\n",
        "level": 3
      },
      {
        "title": "7. Missing integration-level test: full TUI flow end-to-end",
        "content": "\nNo test drives the model through picking → limit → running via real `Update()` calls, which is where regressions in the state machine would actually surface (e.g. viewport sizing before first `WindowSizeMsg`, sidenav highlight tracking during a run).\n\n```go\n// Consider adding github.com/charmbracelet/x/exp/teatest (not currently a\n// dependency) for a scripted end-to-end run:\nfunc TestFullFlowPickLimitRun(t *testing.T) {\n\t// 1. send WindowSizeMsg\n\t// 2. press space on provider 0, enter -> screenLimit\n\t// 3. type \"1\", enter -> screenRunning, assert runOrder/pending\n\t// 4. send statusMsg + doneMsg for the provider, assert sidenav shows done\n\t// 5. assert 'q' now quits (pending==0)\n\tt.Skip(\"gap: no end-to-end model-driven test exists\")\n}\n```\n\n",
        "level": 3
      },
      {
        "title": "8. View-rendering functions — untested, lower priority",
        "content": "\n`viewPicking`, `viewLimit`, `viewRunning`, `View()` produce ANSI/lipgloss-styled strings. Full snapshot testing is low value given styling churn, but a **smoke test** (non-empty output, no panic, contains expected literal substrings like provider names or `\"0 of 11 selected\"`) would catch outright breakage cheaply:\n\n```go\nfunc TestViewsDoNotPanicAndContainKeyText(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tm.width, m.height = 120, 40\n\tif out := m.viewPicking(); !strings.Contains(out, \"IKOTOFETSY\") {\n\t\tt.Error(\"viewPicking missing expected badge text\")\n\t}\n\tm.screen = screenLimit\n\tif out := m.viewLimit(); !strings.Contains(out, \"how many new articles\") {\n\t\tt.Error(\"viewLimit missing expected prompt\")\n\t}\n}\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Summary of gaps by priority",
        "content": "1. **No tests exist at all** — establish `tui_test.go` / `main_test.go` with the pure-function suite in §1 first; zero refactoring required, immediate coverage.\n2. **`handleKey`/`Update` state machine (§2–3)** — the highest-value target; catches real regressions in the interactive flow. No refactor needed.\n3. **Nil-pointer gap on unknown-provider messages (§3)** — worth a guard + regression test even though currently unreachable.\n4. **`truncate` negative-n panic and multi-byte-UTF8 mis-slice (§1)** — latent bugs, currently unreachable via existing call sites, but should be pinned by a test if `truncate` is ever called with dynamic input.\n5. **Subprocess boundary (`runCrawler`, `runHeadless`, `startRun`) is completely untestable as written** — needs a small refactor (inject a `crawlerFn`) before any unit test can cover process-exec error handling, non-zero exit propagation, or stdout/stderr folding. This is the biggest structural gap.\n6. **`main()` dispatch logic** — needs extraction into a testable `run(args []string)` before it's coverable.",
        "level": 3
      }
    ],
    "codeBlocks": [
      {
        "language": "go",
        "code": "// tui_test.go\npackage main\n\nimport \"testing\"\n\nfunc TestArticlesSaved(t *testing.T) {\n\tcases := []struct {\n\t\tname  string\n\t\tlines []string\n\t\twant  int\n\t}{\n\t\t{\"empty\", nil, 0},\n\t\t{\"no matches\", []string{\"fetching...\", \"done\"}, 0},\n\t\t{\"single match\", []string{\"  - 'Title' (2026-07-01)\"}, 1},\n\t\t{\"mixed lines\", []string{\"log line\", \"  - 'A'\", \"log\", \"  - 'B'\"}, 2},\n\t\t{\"prefix-only no trailing content\", []string{\"  - \"}, 1},\n\t\t{\"near-miss indentation not counted\", []string{\" - 'A'\"}, 0}, // single leading space\n\t}\n\tfor _, tc := range cases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tif got := articlesSaved(tc.lines); got != tc.want {\n\t\t\t\tt.Errorf(\"got %d, want %d\", got, tc.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTruncate(t *testing.T) {\n\tcases := []struct {\n\t\tname string\n\t\ts    string\n\t\tn    int\n\t\twant string\n\t}{\n\t\t{\"shorter than n\", \"abc\", 10, \"abc\"},\n\t\t{\"equal to n\", \"abcde\", 5, \"abcde\"},\n\t\t{\"longer, truncates with ellipsis\", \"abcdefgh\", 5, \"abcd…\"},\n\t\t{\"n=1\", \"abcdef\", 1, \"a\"},\n\t\t{\"n=0 on non-empty string\", \"abcdef\", 0, \"\"}, // s[:0]\n\t\t{\"multi-byte rune truncated mid-codepoint\", \"café\", 3, \"\"},\n\t\t// ^ current impl uses len() (bytes) not rune count; 'é' is 2 bytes,\n\t\t//   so this documents/pins the known non-ASCII truncation bug.\n\t}\n\tfor _, tc := range cases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tgot := truncate(tc.s, tc.n)\n\t\t\tif got != tc.want {\n\t\t\t\tt.Errorf(\"truncate(%q, %d) = %q, want %q\", tc.s, tc.n, got, tc.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTruncateNegativeNPanics(t *testing.T) {\n\t// documents a latent bug: truncate(s, negative) panics via negative slice\n\t// index when s is non-empty. Currently unreachable (all call sites pass\n\t// positive literals) but worth guarding if n ever becomes dynamic.\n\tdefer func() {\n\t\tif r := recover(); r == nil {\n\t\t\tt.Error(\"expected panic on negative n, got none — bug may have been fixed, update this test\")\n\t\t}\n\t}()\n\ttruncate(\"abc\", -1)\n}\n\nfunc TestModelLayout(t *testing.T) {\n\tcases := []struct {\n\t\tname       string\n\t\twidth      int\n\t\theight     int\n\t\twantW      int\n\t\twantH      int\n\t}{\n\t\t{\"normal size\", 100, 40, 100 - sidenavWidth - 4, 40 - 6},\n\t\t{\"tiny width clamps to 10\", 5, 40, 10, 34},\n\t\t{\"tiny height clamps to 3\", 100, 2, 68, 3},\n\t\t{\"zero size before first WindowSizeMsg\", 0, 0, 10, 3},\n\t}\n\tfor _, tc := range cases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tm := newModel(10, \"../crawler\")\n\t\t\tm.width, m.height = tc.width, tc.height\n\t\t\tgotW, gotH := m.layout()\n\t\t\tif gotW != tc.wantW || gotH != tc.wantH {\n\t\t\t\tt.Errorf(\"layout() = (%d,%d), want (%d,%d)\", gotW, gotH, tc.wantW, tc.wantH)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestModelHighlighted(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tif got := m.highlighted(); got != \"\" {\n\t\tt.Errorf(\"empty runOrder: got %q, want \\\"\\\"\", got)\n\t}\n\tm.runOrder = []string{\"a\", \"b\"}\n\tm.runCursor = 1\n\tif got := m.highlighted(); got != \"b\" {\n\t\tt.Errorf(\"got %q, want b\", got)\n\t}\n\tm.runCursor = -1\n\tif got := m.highlighted(); got != \"\" {\n\t\tt.Errorf(\"negative cursor: got %q, want \\\"\\\"\", got)\n\t}\n\tm.runCursor = len(m.runOrder)\n\tif got := m.highlighted(); got != \"\" {\n\t\tt.Errorf(\"cursor==len: got %q, want \\\"\\\"\", got)\n\t}\n}\n\nfunc TestModelCountSelected(t *testing.T) {\n\tm := newModel(10, \"../crawler\")\n\tif m.countSelected() != 0 {\n\t\tt.Error(\"expected 0 on fresh model\")\n\t}\n\tm.selected[0] = true\n\tm.selected[1] = false\n\tm.selected[2] = true\n\tif got := m.countSelected(); got != 2 {\n\t\tt.Errorf(\"got %d, want 2\", got)\n\t}\n}"
