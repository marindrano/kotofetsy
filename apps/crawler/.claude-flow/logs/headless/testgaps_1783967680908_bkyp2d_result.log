ct_images`: `data-src` preferred over `src`; `data:` URIs skipped; dedup; cover image included first; relative→absolute via `urljoin`\n- `crawl()` — the most business-critical, least tested logic:\n  - resumability: URLs already in `seen_urls` are skipped\n  - per-article exception → logged, skipped, **not** marked seen (retried next run)\n  - `parse_article` returning `None` → marked seen (never retried) and state persisted immediately\n  - successful save → appended to JSONL, state updated, `on_save` callback fired\n  - `limit > 0` stops exactly at limit with `last_stopped_reason = \"limit reached\"`\n  - `limit <= 0` (unlimited) runs until `list_article_urls()` exhausted, `last_stopped_reason = \"exhausted\"`\n  - discovery-level exception (e.g. `list_article_urls()` raises) → caught, state saved, **not** re-raised\n\n**Missing error-handling tests:** none of the three `except Exception` branches in `crawl()`/`_discover_categories`/etc. are exercised — this is the most valuable gap since resumability correctness hinges on them.\n\n**Suggested test skeletons** (`tests/test_base.py`):\n\n```python\nimport json\nimport gzip\nfrom datetime import date\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\n\nfrom base import (\n    discover_sitemap_urls,\n    parse_french_date,\n    parse_numeric_date,\n    NewsSource,\n)\nfrom models import Article, SiteSelectors\n\n\n# --- pure parsing functions ---\n\n@pytest.mark.parametrize(\"text,expected\", [\n    (\"22 juin 2019\", \"2019-06-22\"),\n    (\"octobre 30, 2017\", \"2017-10-30\"),\n    (\"22 février 2019\", \"2019-02-22\"),\n    (\"22 fevrier 2019\", \"2019-02-22\"),\n    (\"not a date\", None),\n    (\"22 blorptember 2019\", None),\n])\ndef test_parse_french_date(text, expected):\n    assert parse_french_date(text) == expected\n\n\n@pytest.mark.parametrize(\"text,expected\", [\n    (\"13/07/2026\", \"2026-07-13\"),\n    (\"13/07/2026 14:32\", \"2026-07-13\"),\n    (\"no date here\", None),\n])\ndef test_parse_numeric_date(text, expected):\n    assert parse_numeric_date(text) == expected\n\n\n# --- sitemap discovery ---\n\ndef _xml_bytes(s: str) -> bytes:\n    return s.encode(\"utf-8\")\n\nclass _FakeResp:\n    def __init__(self, data: bytes):\n        self._data = data\n    def read(self):\n        return self._data\n    def __enter__(self):\n        return self\n    def __exit__(self, *a):\n        return False\n\ndef test_discover_sitemap_urls_flat_urlset():\n    xml = _xml_bytes(\n        '<urlset><url><loc>https://x/a</loc></url>'\n        '<url><loc>https://x/b</loc></url></urlset>'\n    )\n    with patch(\"urllib.request.urlopen\", return_value=_FakeResp(xml)):\n        urls = list(discover_sitemap_urls(\"https://x/sitemap.xml\"))\n    assert urls == [\"https://x/a\", \"https://x/b\"]\n\ndef test_discover_sitemap_urls_index_recurses():\n    index = _xml_bytes(\n        '<sitemapindex><sitemap><loc>https://x/sub.xml</loc></sitemap></sitemapindex>'\n    )\n    leaf = _xml_bytes('<urlset><url><loc>https://x/a</loc></url></urlset>')\n    with patch(\"urllib.request.urlopen\", side_effect=[_FakeResp(index), _FakeResp(leaf)]):\n        urls = list(discover_sitemap_urls(\"https://x/sitemap_index.xml\"))\n    assert urls == [\"https://x/a\"]\n\ndef test_discover_sitemap_urls_ignores_nested_image_loc():\n    xml = _xml_bytes(\n        '<urlset><url><loc>https://x/a</loc>'\n        '<image:image xmlns:image=\"ns\"><image:loc>https://x/img.jpg</image:loc></image:image>'\n        '</url></urlset>'\n    )\n    with patch(\"urllib.request.urlopen\", return_value=_FakeResp(xml)):\n        urls = list(discover_sitemap_urls(\"https://x/sitemap.xml\"))\n    assert urls == [\"https://x/a\"]\n\ndef test_fetch_xml_handles_gzip_and_leading_whitespace():\n    from base import _fetch_xml\n    payload = gzip.compress(b\"\\n<urlset></urlset>\")\n    with patch(\"urllib.request.urlopen\", return_value=_FakeResp(payload)):\n        assert _fetch_xml(\"https://x/sitemap.xml\") == \"<urlset></urlset>\"\n\n\n# --- NewsSource state/log/persistence ---\n\nclass DummySource(NewsSource):\n    source_name = \"dummy\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\")\n\n@pytest.fixture\ndef source(tmp_path, monkeypatch):\n    import base\n    monkeypatch.setattr(base, \"STATE_DIR\", tmp_path / \"state\")\n    monkeypatch.setattr(base, \"DATA_DIR\", tmp_path / \"data\")\n    monkeypatch.setattr(base, \"LOG_DIR\", tmp_path / \"logs\")\n    return DummySource()\n\ndef test_load_state_defaults_when_missing(source):\n    assert source._load_state() == {\"seen_urls\": [], \"total_saved\": 0}\n\ndef test_save_state_is_atomic_and_roundtrips(source):\n    source._save_state({\"seen_urls\": [\"a\"], \"total_saved\": 1})\n    assert source._load_state()[\"seen_urls\"] == [\"a\"]\n    assert not source._state_path.with_suffix(\".json.tmp\").exists()\n\ndef test_list_article_urls_without_sitemap_raises():\n    with pytest.raises(NotImplementedError):\n        list(DummySource().list_article_urls())\n\ndef test_fetch_uses_stealthy_fetcher_when_needed(monkeypatch):\n    src = DummySource()\n    src.needs_stealth = True\n    with patch(\"base.StealthyFetcher.fetch\") as stealthy, patch(\"base.Fetcher.get\") as plain:\n        src.fetch(\"https://x/a\")\n        stealthy.assert_called_once()\n        plain.assert_not_called()\n\n\n# --- parse_article ---\n\ndef _fake_page(title_text=None, body_paragraphs=None, og_image=None, iframe_src=None):\n    \"\"\"Build a MagicMock mimicking scrapling's page.css(...) chain enough for parse_article.\"\"\"\n    page = MagicMock()\n\n    def css(selector):\n        if selector == \"h1\" and title_text is not None:\n            el = MagicMock()\n            el.get_all_text.return_value = title_text\n            fake = MagicMock()\n            fake.first = el\n            return fake\n        if selector == \"p\":\n            return [MagicMock(get_all_text=MagicMock(return_value=t)) for t in (body_paragraphs or [])]\n        if \"og:image\" in selector:\n            fake = MagicMock()\n            if og_image:\n                el = MagicMock()\n                el.attrib = {\"content\": og_image}\n                fake.first = el\n            else:\n                fake.first = None\n            return fake\n        if selector == \"iframe\":\n            if iframe_src:\n                el = MagicMock()\n                el.attrib = {\"src\": iframe_src}\n                return [el]\n            return []\n        fake = MagicMock()\n        fake.first = None\n        return fake\n\n    page.css.side_effect = css\n    return page\n\ndef test_parse_article_returns_none_when_title_missing():\n    src = DummySource()\n    with patch.object(src, \"fetch\", return_value=_fake_page(title_text=None)):\n        assert src.parse_article(\"https://x/a\") is None\n\ndef test_parse_article_extracts_title_and_body():\n    src = DummySource()\n    page = _fake_page(title_text=\"Hello\", body_paragraphs=[\"Para 1\", \"\", \"Para 2\"])\n    with patch.object(src, \"fetch\", return_value=page):\n        article = src.parse_article(\"https://x/a\")\n    assert article.title == \"Hello\"\n    assert article.body == \"Para 1\\n\\nPara 2\"  # empty paragraph filtered\n\n\n# --- crawl() orchestration ---\n\ndef test_crawl_skips_already_seen_urls(source):\n    source._save_state({\"seen_urls\": [\"https://x/a\"], \"total_saved\": 1})\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\"])), \\\n         patch.object(source, \"parse_article\") as parse_mock:\n        result = source.crawl(limit=10)\n    parse_mock.assert_not_called()\n    assert result == []\n\ndef test_crawl_continues_after_per_article_exception(source):\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\", \"https://x/b\"])), \\\n         patch.object(source, \"parse_article\", side_effect=[Exception(\"boom\"), Article(\n             url=\"https://x/b\", title=\"t\", body=\"b\", author=None, published_date=None,\n             category=None, source=\"dummy\", scraped_at=\"now\",\n         )]):\n        result = source.crawl(limit=10)\n    assert len(result) == 1\n    state = source._load_state()\n    assert \"https://x/a\" not in state[\"seen_urls\"]  # transient error -> retry next run\n    assert \"https://x/b\" in state[\"seen_urls\"]\n\ndef test_crawl_marks_non_article_as_seen_without_saving(source):\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\"])), \\\n         patch.object(source, \"parse_article\", return_value=None):\n        result = source.crawl(limit=10)\n    assert result == []\n    assert \"https://x/a\" in source._load_state()[\"seen_urls\"]\n\ndef test_crawl_stops_at_limit(source):\n    urls = [f\"https://x/{i}\" for i in range(5)]\n    articles = [Article(url=u, title=\"t\", body=\"b\", author=None, published_date=None,\n                         category=None, source=\"dummy\", scraped_at=\"now\") for u in urls]\n    with patch.object(source, \"list_article_urls\", return_value=iter(urls)), \\\n         patch.object(source, \"parse_article\", side_effect=articles):\n        result = source.crawl(limit=2)\n    assert len(result) == 2\n    assert source._load_state()[\"last_stopped_reason\"] == \"limit reached\"\n\ndef test_crawl_unlimited_runs_until_exhausted(source):\n    with patch.object(source, \"list_article_urls\", return_value=iter([])):\n        result = source.crawl(limit=0)\n    assert result == []\n    assert source._load_state()[\"last_stopped_reason\"] == \"exhausted\"\n\ndef test_crawl_discovery_exception_caught_and_state_saved(source):\n    def broken_iter():\n        raise RuntimeError(\"network cut\")\n        yield  # pragma: no cover\n    with patch.object(source, \"list_article_urls\", return_value=broken_iter()):\n        result = source.crawl(limit=10)  # must not raise\n    assert result == []\n    assert \"error: network cut\" in source._load_state()[\"last_stopped_reason\"]\n\ndef test_crawl_invokes_on_save_callback(source):\n    article = Article(url=\"https://x/a\", title=\"t\", body=\"b\", author=None,\n                       published_date=None, category=None, source=\"dummy\", scraped_at=\"now\")\n    on_save = MagicMock()\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\"])), \\\n         patch.object(source, \"parse_article\", return_value=article):\n        source.crawl(limit=10, on_save=on_save)\n    on_save.assert_called_once_with(article)\n```\n\n---\n\n### 2. `providers.py` — pure-logic branches are cheap wins, network crawlers need mocking\n\n**Untested, no-HTTP-dependency logic (easiest, highest ROI):**\n- `MadagascarTribune._is_article_link` — 4 independent boolean branches, zero I/O, no excuse to skip\n\n```python\nimport pytest\nfrom providers import MadagascarTribune\n\n@pytest.mark.parametrize(\"href,expected\", [\n    (\"some-article.html\", True),\n    (\"category-.html\", False),          # rubrique convention, not article\n    (\"https://external.com/a.html\", False),\n    (\"/absolute/path.html\", False),\n    (\"_AuthorName,42_.html\", False),    # byline page\n    (\"no-extension\", False),\n    (None, False),\n])\ndef test_is_article_link(href, expected):\n    assert MadagascarTribune._is_article_link(href) is expected\n```\n\n**Untested, HTTP-mocked crawlers:**\n- `MadagascarTribune._discover_categories`: rubrique-id regex extraction, dedup+sort by int, homepage-fetch failure → `[]`\n- `MadagascarTribune.list_article_urls`: pagination stops when a page yields 0 new links; per-category fetch exception breaks that category only (not the whole crawl); redirect URL (`page.url`) used for subsequent pagination\n- `FreeNews.list_article_urls`: pages until empty list; `HTTPError(400)` → stop (past last page); any other `HTTPError` → re-raised (not swallowed) — **this distinction is currently untested and easy to break**\n- `Moov.list_article_urls`: BFS dedup via `queued` set; only `/article/` links enqueued; fetch failure during frontier expansion doesn't stop the whole crawl (`continue`)\n- `PROVIDERS` registry: every entry's `source_name` matches its dict key (a copy-paste bug here silently breaks state/log/data paths)\n\n```python\ndef test_providers_registry_keys_match_source_name():\n    from providers import PROVIDERS\n    for key, cls in PROVIDERS.items():\n        assert cls.source_name == key\n\ndef test_freenews_stops_on_400_but_reraises_other_http_errors():\n    import urllib.error\n    from unittest.mock import patch\n    from providers import FreeNews\n    src = FreeNews()\n    with patch(\"providers.urllib.request.urlopen\",\n               side_effect=urllib.error.HTTPError(\"u\", 400, \"x\", {}, None)):\n        assert list(src.list_article_urls()) == []\n    with patch(\"providers.urllib.request.urlopen\",\n               side_effect=urllib.error.HTTPError(\"u\", 500, \"x\", {}, None)):\n        with pytest.raises(urllib.error.HTTPError):\n            list(src.list_article_urls())\n```\n\n---\n\n### 3. `models.py` — low risk, but worth a smoke test for defaults\n\n```python\nfrom models import Article, SiteSelectors\n\ndef test_article_images_default_factory_is_independent_per_instance():\n    a1 = Article(url=\"a\", title=\"t\", body=\"b\", author=None, published_date=None,\n                 category=None, source=\"s\", scraped_at=\"now\")\n    a2 = Article(url=\"b\", title=\"t\", body=\"b\", author=None, published_date=None,\n                 category=None, source=\"s\", scraped_at=\"now\")\n    a1.images.append(\"x\")\n    assert a2.images == []  # guards against a future `images: list = []` mutable-default regression\n```\n\n---\n\n### 4. `main.py` — CLI argument handling and orchestration untested\n\n- `--provider all` expands to every key in `PROVIDERS`, in dict order\n- invalid provider name is rejected by `argparse` (choices)\n- `--limit` default is `10` and is passed through to `crawl()`\n- each provider's `crawl()` is invoked once with `on_save` set\n\n```python\nfrom unittest.mock import patch, MagicMock\nimport sys\nfrom main import main\n\ndef test_main_all_expands_to_every_provider(monkeypatch):\n    fake_source = MagicMock()\n    fake_source.crawl.return_value = []\n    with patch(\"main.PROVIDERS\", {\"a\": MagicMock(return_value=fake_source),\n                                   \"b\": MagicMock(return_value=fake_source)}), \\\n         patch.object(sys, \"argv\", [\"main.py\", \"all\"]):\n        main()\n    assert fake_source.crawl.call_count == 2\n\ndef test_main_passes_limit_through(monkeypatch):\n    fake_source = MagicMock()\n    fake_source.crawl.return_value = []\n    fake_cls = MagicMock(return_value=fake_source)\n    with patch(\"main.PROVIDERS\", {\"a\": fake_cls}), \\\n         patch.object(sys, \"argv\", [\"main.py\", \"a\", \"--limit\", \"5\"]):\n        main()\n    _, kwargs = fake_source.crawl.call_args\n    assert kwargs[\"limit\"] == 5\n```\n\n---\n\n### 5. Integration test gaps\n\nThere is no test that exercises a full `crawl()` cycle against a realistic fixture (saved HTML/sitemap XML) end-to-end for at least one real provider (e.g. record a static sitemap + article HTML fixture for `lexpress-mg`, run `crawl(limit=1)` against it via a stubbed `Fetcher`, assert the JSONL/state files produced). This is the one test that would catch selector regressions when a provider's HTML changes — currently the only signal for that is a silent empty-`body`/`None` in production.\n\nAlso missing: a resumability integration test — run `crawl()` twice against the same fixture data and assert the second run saves 0 new articles (proves `seen_urls` + state file wiring works end-to-end, not just in isolation).\n\n---\n\n### Setup needed to unblock this\n\n`pyproject.toml` has `pytest` as a dev dependency but no `tests/` directory, no `conftest.py`, and no pytest config (`[tool.pytest.ini_options]`) pointing at a test path. Per project rules, tests should live under `apps/crawler/tests/` (not root). Want me to scaffold `tests/` with these skeletons as actual files, or was this analysis-only?\n",
