      {
        "title": "--- crawl() orchestration ---",
        "content": "\ndef test_crawl_skips_already_seen_urls(source):\n    source._save_state({\"seen_urls\": [\"https://x/a\"], \"total_saved\": 1})\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\"])), \\\n         patch.object(source, \"parse_article\") as parse_mock:\n        result = source.crawl(limit=10)\n    parse_mock.assert_not_called()\n    assert result == []\n\ndef test_crawl_continues_after_per_article_exception(source):\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\", \"https://x/b\"])), \\\n         patch.object(source, \"parse_article\", side_effect=[Exception(\"boom\"), Article(\n             url=\"https://x/b\", title=\"t\", body=\"b\", author=None, published_date=None,\n             category=None, source=\"dummy\", scraped_at=\"now\",\n         )]):\n        result = source.crawl(limit=10)\n    assert len(result) == 1\n    state = source._load_state()\n    assert \"https://x/a\" not in state[\"seen_urls\"]  # transient error -> retry next run\n    assert \"https://x/b\" in state[\"seen_urls\"]\n\ndef test_crawl_marks_non_article_as_seen_without_saving(source):\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\"])), \\\n         patch.object(source, \"parse_article\", return_value=None):\n        result = source.crawl(limit=10)\n    assert result == []\n    assert \"https://x/a\" in source._load_state()[\"seen_urls\"]\n\ndef test_crawl_stops_at_limit(source):\n    urls = [f\"https://x/{i}\" for i in range(5)]\n    articles = [Article(url=u, title=\"t\", body=\"b\", author=None, published_date=None,\n                         category=None, source=\"dummy\", scraped_at=\"now\") for u in urls]\n    with patch.object(source, \"list_article_urls\", return_value=iter(urls)), \\\n         patch.object(source, \"parse_article\", side_effect=articles):\n        result = source.crawl(limit=2)\n    assert len(result) == 2\n    assert source._load_state()[\"last_stopped_reason\"] == \"limit reached\"\n\ndef test_crawl_unlimited_runs_until_exhausted(source):\n    with patch.object(source, \"list_article_urls\", return_value=iter([])):\n        result = source.crawl(limit=0)\n    assert result == []\n    assert source._load_state()[\"last_stopped_reason\"] == \"exhausted\"\n\ndef test_crawl_discovery_exception_caught_and_state_saved(source):\n    def broken_iter():\n        raise RuntimeError(\"network cut\")\n        yield  # pragma: no cover\n    with patch.object(source, \"list_article_urls\", return_value=broken_iter()):\n        result = source.crawl(limit=10)  # must not raise\n    assert result == []\n    assert \"error: network cut\" in source._load_state()[\"last_stopped_reason\"]\n\ndef test_crawl_invokes_on_save_callback(source):\n    article = Article(url=\"https://x/a\", title=\"t\", body=\"b\", author=None,\n                       published_date=None, category=None, source=\"dummy\", scraped_at=\"now\")\n    on_save = MagicMock()\n    with patch.object(source, \"list_article_urls\", return_value=iter([\"https://x/a\"])), \\\n         patch.object(source, \"parse_article\", return_value=article):\n        source.crawl(limit=10, on_save=on_save)\n    on_save.assert_called_once_with(article)\n```\n\n---\n\n",
