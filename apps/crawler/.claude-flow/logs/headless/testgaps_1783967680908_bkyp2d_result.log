fect=[_FakeResp(index), _FakeResp(leaf)]):\n        urls = list(discover_sitemap_urls(\"https://x/sitemap_index.xml\"))\n    assert urls == [\"https://x/a\"]\n\ndef test_discover_sitemap_urls_ignores_nested_image_loc():\n    xml = _xml_bytes(\n        '<urlset><url><loc>https://x/a</loc>'\n        '<image:image xmlns:image=\"ns\"><image:loc>https://x/img.jpg</image:loc></image:image>'\n        '</url></urlset>'\n    )\n    with patch(\"urllib.request.urlopen\", return_value=_FakeResp(xml)):\n        urls = list(discover_sitemap_urls(\"https://x/sitemap.xml\"))\n    assert urls == [\"https://x/a\"]\n\ndef test_fetch_xml_handles_gzip_and_leading_whitespace():\n    from base import _fetch_xml\n    payload = gzip.compress(b\"\\n<urlset></urlset>\")\n    with patch(\"urllib.request.urlopen\", return_value=_FakeResp(payload)):\n        assert _fetch_xml(\"https://x/sitemap.xml\") == \"<urlset></urlset>\"\n\n\n# --- NewsSource state/log/persistence ---\n\nclass DummySource(NewsSource):\n    source_name = \"dummy\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\")\n\n@pytest.fixture\ndef source(tmp_path, monkeypatch):\n    import base\n    monkeypatch.setattr(base, \"STATE_DIR\", tmp_path / \"state\")\n    monkeypatch.setattr(base, \"DATA_DIR\", tmp_path / \"data\")\n    monkeypatch.setattr(base, \"LOG_DIR\", tmp_path / \"logs\")\n    return DummySource()\n\ndef test_load_state_defaults_when_missing(source):\n    assert source._load_state() == {\"seen_urls\": [], \"total_saved\": 0}\n\ndef test_save_state_is_atomic_and_roundtrips(source):\n    source._save_state({\"seen_urls\": [\"a\"], \"total_saved\": 1})\n    assert source._load_state()[\"seen_urls\"] == [\"a\"]\n    assert not source._state_path.with_suffix(\".json.tmp\").exists()\n\ndef test_list_article_urls_without_sitemap_raises():\n    with pytest.raises(NotImplementedError):\n        list(DummySource().list_article_urls())\n\ndef test_fetch_uses_stealthy_fetcher_when_needed(monkeypatch):\n    src = DummySou