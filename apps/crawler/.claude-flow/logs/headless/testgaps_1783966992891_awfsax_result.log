        "code": "# tests/conftest.py\nimport pytest\nfrom models import Article, SiteSelectors\nfrom base import NewsSource\n\nclass FakeSource(NewsSource):\n    source_name = \"fake\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\")\n\n    def __init__(self, urls, parse_results=None, raise_on=None):\n        self._urls = urls\n        self._parse_results = parse_results or {}\n        self._raise_on = raise_on or {}\n\n    def list_article_urls(self):\n        yield from self._urls\n\n    def parse_article(self, url):\n        if url in self._raise_on:\n            raise self._raise_on[url]\n        return self._parse_results.get(url)  # None simulates \"not an article\"\n\n@pytest.fixture\ndef redirect_dirs(tmp_path, monkeypatch):\n    monkeypatch.setattr(\"base.DATA_DIR\", tmp_path / \"data\")\n    monkeypatch.setattr(\"base.STATE_DIR\", tmp_path / \"state\")\n    monkeypatch.setattr(\"base.LOG_DIR\", tmp_path / \"logs\")\n    return tmp_path"
