        "content": "from unittest.mock import patch\nfrom models import SiteSelectors\nfrom base import NewsSource\nfrom tests.conftest import FakePage, FakeElement, FakeSource\n\ndef source_with_page(page, selectors=None):\n    src = FakeSource([])\n    src.selectors = selectors or SiteSelectors(title=\"h1\", body=\"p\")\n    src.fetch = lambda url: page\n    return src\n\ndef test_parse_article_returns_none_when_title_missing():\n    page = FakePage({})  # no h1 at all\n    src = source_with_page(page)\n    assert src.parse_article(\"https://x/1\") is None\n\ndef test_parse_article_joins_nonempty_body_paragraphs():\n    page = FakePage({\n        \"h1\": [FakeElement(\"Title\")],\n        \"p\": [FakeElement(\"Para 1\"), FakeElement(\"  \"), FakeElement(\"Para 2\")],\n    })\n    src = source_with_page(page)\n    article = src.parse_article(\"https://x/1\")\n    assert article.body == \"Para 1\\n\\nPara 2\"  # blank paragraph excluded\n\ndef test_parse_article_published_date_attr_path():\n    selectors = SiteSelectors(title=\"h1\", body=\"p\", published_date=\"time\",\n                               published_date_attr=\"datetime\")\n    page = FakePage({\n        \"h1\": [FakeElement(\"T\")], \"p\": [],\n        \"time\": [FakeElement(attrib={\"datetime\": \"2020-01-01\"})],\n    })\n    src = source_with_page(page, selectors)\n    assert src.parse_article(\"https://x/1\").published_date == \"2020-01-01\"\n\ndef test_parse_article_published_date_french_text_path():\n    selectors = SiteSelectors(title=\"h1\", body=\"p\", published_date=\"span\",\n                               published_date_format=\"french\")\n    page = FakePage({\"h1\": [FakeElement(\"T\")], \"p\": [], \"span\": [FakeElement(\"22 juin 2019\")]})\n    src = source_with_page(page, selectors)\n    assert src.parse_article(\"https://x/1\").published_date == \"2019-06-22\"\n\ndef test_parse_article_embed_url_prefers_iframe_over_video():\n    page = FakePage({\n        \"h1\": [FakeElement(\"T\")], \"p\": [],\n        \"iframe\": [FakeElement(attrib={\"src\": \"https://youtube.com/embed/1\"})],\n        \"video source\": [FakeElement(attrib={\"src\": \"https://x/v.mp4\"})],\n    })\n    src = source_with_page(page)\n    assert src.parse_article(\"https://x/1\").embed_url == \"https://youtube.com/embed/1\"\n\ndef test_parse_article_embed_url_skips_about_blank_iframe():\n    page = FakePage({\n        \"h1\": [FakeElement(\"T\")], \"p\": [],\n        \"iframe\": [FakeElement(attrib={\"src\": \"about:blank\"})],\n        \"video source\": [FakeElement(attrib={\"src\": \"https://x/v.mp4\"})],\n    })\n    src = source_with_page(page)\n    assert src.parse_article(\"https://x/1\").embed_url == \"https://x/v.mp4\"\n\ndef test_parse_article_no_embed_when_no_iframe_or_video():\n    page = FakePage({\"h1\": [FakeElement(\"T\")], \"p\": []})\n    src = source_with_page(page)\n    assert src.parse_article(\"https://x/1\").embed_url is None\n```\n\n`_extract_images` in isolation:\n```python\n",
