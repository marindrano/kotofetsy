        "content": "from models import Article\n\ndef make_article(url):\n    return Article(url=url, title=\"t\", body=\"b\", author=None,\n                    published_date=None, category=None, source=\"fake\",\n                    scraped_at=\"2026-01-01T00:00:00\")\n\ndef test_crawl_stops_at_limit(redirect_dirs):\n    urls = [f\"https://x/{i}\" for i in range(5)]\n    results = {u: make_article(u) for u in urls}\n    source = FakeSource(urls, parse_results=results)\n    saved = source.crawl(limit=2)\n    assert len(saved) == 2\n    state = source._load_state()\n    assert state[\"last_stopped_reason\"] == \"limit reached\"\n\ndef test_crawl_unlimited_exhausts_all_urls(redirect_dirs):\n    urls = [f\"https://x/{i}\" for i in range(3)]\n    results = {u: make_article(u) for u in urls}\n    source = FakeSource(urls, parse_results=results)\n    saved = source.crawl(limit=0)\n    assert len(saved) == 3\n    assert source._load_state()[\"last_stopped_reason\"] == \"exhausted\"\n\ndef test_crawl_skips_already_seen_urls(redirect_dirs):\n    url = \"https://x/1\"\n    source = FakeSource([url], parse_results={url: make_article(url)})\n    source._save_state({\"seen_urls\": [url], \"total_saved\": 0})\n    saved = source.crawl(limit=10)\n    assert saved == []  # never re-fetched\n\ndef test_crawl_marks_non_article_as_seen_without_saving(redirect_dirs):\n    url = \"https://x/not-an-article\"\n    source = FakeSource([url], parse_results={url: None})\n    saved = source.crawl(limit=10)\n    assert saved == []\n    assert url in source._load_state()[\"seen_urls\"]  # so it's never retried\n\ndef test_crawl_continues_after_parse_error_and_does_not_mark_seen(redirect_dirs):\n    bad, good = \"https://x/bad\", \"https://x/good\"\n    source = FakeSource(\n        [bad, good],\n        parse_results={good: make_article(good)},\n        raise_on={bad: RuntimeError(\"network blip\")},\n    )\n    saved = source.crawl(limit=10)\n    assert [a.url for a in saved] == [good]\n    assert bad not in source._load_state()[\"seen_urls\"]  # retried next run, per the comment's intent\n\ndef test_crawl_discovery_failure_preserves_prior_progress_and_reraises(redirect_dirs):\n    def bad_discovery():\n        yield \"https://x/ok\"\n        raise ConnectionError(\"network cut\")\n    source = FakeSource([])\n    source.list_article_urls = bad_discovery\n    source._parse_results = {\"https://x/ok\": make_article(\"https://x/ok\")}\n    source.parse_article = lambda url: source._parse_results.get(url)\n    with pytest.raises(ConnectionError):\n        source.crawl(limit=10)\n    state = source._load_state()\n    assert state[\"last_stopped_reason\"].startswith(\"error:\")\n    assert \"https://x/ok\" in state[\"seen_urls\"]  # the one article before the crash is intact\n\ndef test_crawl_calls_on_save_callback(redirect_dirs):\n    url = \"https://x/1\"\n    source = FakeSource([url], parse_results={url: make_article(url)})\n    calls = []\n    source.crawl(limit=10, on_save=calls.append)\n    assert len(calls) == 1 and calls[0].url == url\n```\n\n",
