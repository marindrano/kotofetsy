        "title": "tests/test_providers_moov.py",
        "content": "from unittest.mock import patch, Mock\nfrom providers import Moov\n\ndef fake_page(links):\n    p = Mock()\n    p.css = Mock(return_value=[Mock(attrib={\"href\": h}) for h in links])\n    return p\n\ndef test_list_article_urls_bfs_dedupes_and_filters_non_article_links():\n    source = Moov()\n    with patch(\"providers.Fetcher.get\") as mock_get:\n        mock_get.side_effect = [\n            fake_page([\"/article/1\", \"/article/2\", \"/not-article/x\"]),  # home\n            fake_page([\"/article/1\", \"/article/3\"]),                    # from /article/1 (1 is a dupe)\n            fake_page([]),                                              # from /article/2\n            fake_page([]),                                              # from /article/3\n        ]\n        urls = list(source.list_article_urls())\n    assert sorted(urls) == sorted([\n        \"https://new.moov.mg/article/1\",\n        \"https://new.moov.mg/article/2\",\n        \"https://new.moov.mg/article/3\",\n    ])\n\ndef test_list_article_urls_continues_frontier_when_a_page_fetch_fails():\n    source = Moov()\n    with patch(\"providers.Fetcher.get\") as mock_get:\n        mock_get.side_effect = [\n            fake_page([\"/article/1\", \"/article/2\"]),\n            RuntimeError(\"fetch failed\"),   # expanding /article/1 fails\n            fake_page([]),                  # /article/2 still expands fine\n        ]\n        urls = list(source.list_article_urls())\n    assert set(urls) == {\"https://new.moov.mg/article/1\", \"https://new.moov.mg/article/2\"}\n```\n\n---\n\n",
