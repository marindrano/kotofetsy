        "code": "from unittest.mock import MagicMock\nfrom base import NewsSource\nfrom models import SiteSelectors\n\nclass FakeSource(NewsSource):\n    source_name = \"fake\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\", author=\"span.author\",\n                               published_date=\"time\", published_date_attr=\"datetime\",\n                               category=\"a.cat\")\n\ndef make_page(css_map, has_title=True):\n    \"\"\"css_map: selector -> list of fake elements\"\"\"\n    page = MagicMock()\n    page.css.side_effect = lambda sel: css_map.get(sel, [])\n    return page\n\ndef make_el(text=\"\", attrib=None):\n    el = MagicMock()\n    el.get_all_text.return_value = text\n    el.attrib = attrib or {}\n    return el\n\ndef test_parse_article_returns_none_when_title_missing():\n    src = FakeSource()\n    page = make_page({\"h1\": []})\n    with patch.object(src, \"fetch\", return_value=page):\n        assert src.parse_article(\"https://x/a\") is None\n\ndef test_parse_article_extracts_all_fields():\n    title_el = make_el(\"My Title\")\n    date_el = make_el(attrib={\"datetime\": \"2024-01-01\"})\n    page = make_page({\n        \"h1\": [MagicMock(first=title_el)],  # see note below on `.first` API shape\n    })\n    # NOTE: adapt mocking to scrapling's actual `.css(...).first` chained API —\n    # `page.css(sel)` returns a selector-list-like object with `.first`.\n    ...\n\ndef test_extract_images_prefers_data_src_and_dedupes():\n    src = FakeSource()\n    img1 = make_el(attrib={\"data-src\": \"/img1.jpg\", \"src\": \"/placeholder.gif\"})\n    img2 = make_el(attrib={\"src\": \"https://cdn/img1.jpg\"})  # same absolute URL as cover\n    page = MagicMock()\n    page.css.return_value = [img1, img2]\n    images = src._extract_images(page, \"https://site.mg/article\", cover_image=\"https://cdn/img1.jpg\")\n    assert images == [\"https://cdn/img1.jpg\"]  # cover first, dedup drops img2, img1 resolved+kept\n\ndef test_extract_images_skips_data_uris():\n    src = FakeSource()\n    img = make_el(attrib={\"src\": \"data:image/png;base64,AAAA\"})\n    page = MagicMock(); page.css.return_value = [img]\n    assert src._extract_images(page, \"https://site.mg/a\", None) == []"
