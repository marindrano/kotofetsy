        "code": "import json\nimport pytest\nfrom base import NewsSource\nfrom models import Article, SiteSelectors\n\nclass StubSource(NewsSource):\n    source_name = \"stub\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\")\n\n@pytest.fixture\ndef stub(tmp_path, monkeypatch):\n    src = StubSource()\n    monkeypatch.setattr(type(src), \"_state_path\", property(lambda self: tmp_path / \"state.json\"))\n    monkeypatch.setattr(type(src), \"_data_path\", property(lambda self: tmp_path / \"articles.jsonl\"))\n    monkeypatch.setattr(type(src), \"_log_path\", property(lambda self: tmp_path / \"log.log\"))\n    return src\n\ndef make_article(url):\n    return Article(url=url, title=\"t\", body=\"b\", author=None, published_date=None,\n                   category=None, source=\"stub\", scraped_at=\"2024-01-01T00:00:00\")\n\ndef test_crawl_respects_limit_and_stops_mid_discovery(stub, monkeypatch):\n    urls = [f\"https://x/{i}\" for i in range(5)]\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter(urls))\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: make_article(u))\n    saved = stub.crawl(limit=2)\n    assert len(saved) == 2\n    state = json.loads(stub._state_path.read_text())\n    assert state[\"last_stopped_reason\"] == \"limit reached\"\n    assert len(state[\"seen_urls\"]) == 2  # only the 2 consumed, not all 5\n\ndef test_crawl_unlimited_exhausts_all(stub, monkeypatch):\n    urls = [f\"https://x/{i}\" for i in range(3)]\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter(urls))\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: make_article(u))\n    saved = stub.crawl(limit=0)\n    assert len(saved) == 3\n    assert json.loads(stub._state_path.read_text())[\"last_stopped_reason\"] == \"exhausted\"\n\ndef test_crawl_skips_already_seen_urls(stub, monkeypatch):\n    stub._state_path.parent.mkdir(parents=True, exist_ok=True)\n    stub._state_path.write_text(json.dumps({\"seen_urls\": [\"https://x/0\"], \"total_saved\": 1}))\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter([\"https://x/0\", \"https://x/1\"]))\n    calls = []\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: (calls.append(u), make_article(u))[1])\n    stub.crawl(limit=10)\n    assert calls == [\"https://x/1\"]  # x/0 never re-parsed\n\ndef test_crawl_parse_error_is_logged_and_url_retried_next_run(stub, monkeypatch):\n    \"\"\"Gap: distinguishes transient fetch/parse errors (NOT marked seen, retried)\n    from structural non-articles (marked seen, never retried again).\"\"\"\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter([\"https://x/bad\"]))\n    def boom(u):\n        raise RuntimeError(\"network blip\")\n    monkeypatch.setattr(stub, \"parse_article\", boom)\n    saved = stub.crawl(limit=10)\n    assert saved == []\n    state = json.loads(stub._state_path.read_text())\n    assert \"https://x/bad\" not in state.get(\"seen_urls\", [])  # must be retried, not permanently skipped\n    assert \"error fetching https://x/bad\" in stub._log_path.read_text()\n\ndef test_crawl_non_article_page_is_marked_seen_permanently(stub, monkeypatch):\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter([\"https://x/tagpage\"]))\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: None)  # title selector didn't match\n    stub.crawl(limit=10)\n    state = json.loads(stub._state_path.read_text())\n    assert \"https://x/tagpage\" in state[\"seen_urls\"]  # permanently skipped, unlike a fetch error\n\ndef test_crawl_discovery_failure_preserves_prior_saved_state(stub, monkeypatch):\n    \"\"\"Gap: discovery-level exception (e.g. sitemap fetch fails mid-walk) must not\n    lose articles already saved earlier in the SAME run, and must not raise.\"\"\"\n    def failing_urls():\n        yield \"https://x/ok\"\n        raise ConnectionError(\"network cut\")\n    monkeypatch.setattr(stub, \"list_article_urls\", failing_urls)\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: make_article(u))\n    saved = stub.crawl(limit=10)  # must NOT raise\n    assert len(saved) == 1\n    state = json.loads(stub._state_path.read_text())\n    assert state[\"last_stopped_reason\"].startswith(\"error:\")\n    assert state[\"total_saved\"] == 1\n\ndef test_append_article_writes_valid_jsonl_line(stub):\n    stub._append_article(make_article(\"https://x/1\"))\n    line = stub._data_path.read_text().splitlines()[0]\n    assert json.loads(line)[\"url\"] == \"https://x/1\"\n\ndef test_load_state_missing_file_returns_defaults(stub):\n    assert stub._load_state() == {\"seen_urls\": [], \"total_saved\": 0}"
