 responses = {\"https://site.mg/sitemap.xml\": INDEX_SITEMAP.decode(),\n                 \"https://site.mg/sub1.xml\": FLAT_SITEMAP.decode()}\n    with patch(\"base._fetch_xml\", side_effect=lambda url: responses[url]):\n        urls = list(discover_sitemap_urls(\"https://site.mg/sitemap.xml\"))\n    assert urls == [\"https://site.mg/a\", \"https://site.mg/b\"]\n\ndef test_fetch_xml_handles_gzip_and_leading_newline():\n    import gzip\n    from base import _fetch_xml\n    payload = gzip.compress(b\"\\n<?xml version='1.0'?><a/>\")\n    fake_resp = MagicMock()\n    fake_resp.read.return_value = payload\n    fake_resp.__enter__.return_value = fake_resp\n    with patch(\"urllib.request.urlopen\", return_value=fake_resp):\n        assert _fetch_xml(\"https://x\").startswith(\"<?xml\")\n```\n\n**No test for `_fetch_xml` network failure propagation** (timeout, `URLError`) — currently uncaught inside `_fetch_xml`/`discover_sitemap_urls`; relied upon to bubble to `crawl()`'s outer `except`. Needs an integration-level test (see §3).\n\n---\n\n### 2. `base.py` — `NewsSource.parse_article` (largest untested surface)\n\nNo test constructs a fake `page` object and exercises the selector branches. Missing scenarios:\n\n- title selector matches nothing → returns `None` (early return, base.py:178-180)\n- `author`/`published_date`/`category` selectors present in `SiteSelectors` but element not found on page → falls back to `None` cleanly\n- `published_date_attr` set → reads attribute; not set → reads text; `published_date_format=\"french\"` vs `\"numeric\"` vs unset (raw text passthrough)\n- `cover_image` via `og:image` meta present/absent\n- `embed_url`: iframe present but `src=\"about:blank\"` → falls through to `<video source>` check\n- `_extract_images` (base.py:254-271): dedup across cover_image + body images, `data-src` preferred over `src`, `data:` URIs skipped, relative URLs resolved via `urljoin`\n\n```python\nfrom unittest.mock import MagicMock\nfrom base import NewsSource\nfrom models import SiteSelectors\n\nclass FakeSource(NewsSource):\n    source_name = \"fake\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\", author=\"span.author\",\n                               published_date=\"time\", published_date_attr=\"datetime\",\n                               category=\"a.cat\")\n\ndef make_page(css_map, has_title=True):\n    \"\"\"css_map: selector -> list of fake elements\"\"\"\n    page = MagicMock()\n    page.css.side_effect = lambda sel: css_map.get(sel, [])\n    return page\n\ndef make_el(text=\"\", attrib=None):\n    el = MagicMock()\n    el.get_all_text.return_value = text\n    el.attrib = attrib or {}\n    return el\n\ndef test_parse_article_returns_none_when_title_missing():\n    src = FakeSource()\n    page = make_page({\"h1\": []})\n    with patch.object(src, \"fetch\", return_value=page):\n        assert src.parse_article(\"https://x/a\") is None\n\ndef test_parse_article_extracts_all_fields():\n    title_el = make_el(\"My Title\")\n    date_el = make_el(attrib={\"datetime\": \"2024-01-01\"})\n    page = make_page({\n        \"h1\": [MagicMock(first=title_el)],  # see note below on `.first` API shape\n    })\n    # NOTE: adapt mocking to scrapling's actual `.css(...).first` chained API —\n    # `page.css(sel)` returns a selector-list-like object with `.first`.\n    ...\n\ndef test_extract_images_prefers_data_src_and_dedupes():\n    src = FakeSource()\n    img1 = make_el(attrib={\"data-src\": \"/img1.jpg\", \"src\": \"/placeholder.gif\"})\n    img2 = make_el(attrib={\"src\": \"https://cdn/img1.jpg\"})  # same absolute URL as cover\n    page = MagicMock()\n    page.css.return_value = [img1, img2]\n    images = src._extract_images(page, \"https://site.mg/article\", cover_image=\"https://cdn/img1.jpg\")\n    assert images == [\"https://cdn/img1.jpg\"]  # cover first, dedup drops img2, img1 resolved+kept\n\ndef test_extract_images_skips_data_uris():\n    src = FakeSource()\n    img = make_el(attrib={\"src\": \"data:image/png;base64,AAAA\"})\n    page = MagicMock(); page.css.return_value = [img]\n    assert src._extract_images(page, \"https://site.mg/a\", None) == []\n```\n\nNote on mocking `scrapling`'s `.css(...).first` chained API: the real return type isn't a plain list — check `Fetcher`/`StealthyFetcher` response shape once (e.g. via a quick REPL or scrapling's own tests) before finalizing these mocks, since `.first` may be a property that raises on an empty list rather than returning `None`.\n\n---\n\n### 3. `base.py` — `NewsSource.crawl()` (most important gap: resumability + error semantics)\n\nThis is the riskiest untested code — it's where state-file correctness, retry-vs-permanent-skip logic, and limit/exhaustion boundaries live. Recommended approach: a `FakeSource` with monkeypatched `list_article_urls`/`parse_article`, and `tmp_path`-redirected `STATE_DIR`/`DATA_DIR`/`LOG_DIR` (monkeypatch the module constants, or monkeypatch the `_state_path`/`_data_path`/`_log_path` properties directly — simpler and avoids cross-test file pollution).\n\n```python\nimport json\nimport pytest\nfrom base import NewsSource\nfrom models import Article, SiteSelectors\n\nclass StubSource(NewsSource):\n    source_name = \"stub\"\n    selectors = SiteSelectors(title=\"h1\", body=\"p\")\n\n@pytest.fixture\ndef stub(tmp_path, monkeypatch):\n    src = StubSource()\n    monkeypatch.setattr(type(src), \"_state_path\", property(lambda self: tmp_path / \"state.json\"))\n    monkeypatch.setattr(type(src), \"_data_path\", property(lambda self: tmp_path / \"articles.jsonl\"))\n    monkeypatch.setattr(type(src), \"_log_path\", property(lambda self: tmp_path / \"log.log\"))\n    return src\n\ndef make_article(url):\n    return Article(url=url, title=\"t\", body=\"b\", author=None, published_date=None,\n                   category=None, source=\"stub\", scraped_at=\"2024-01-01T00:00:00\")\n\ndef test_crawl_respects_limit_and_stops_mid_discovery(stub, monkeypatch):\n    urls = [f\"https://x/{i}\" for i in range(5)]\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter(urls))\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: make_article(u))\n    saved = stub.crawl(limit=2)\n    assert len(saved) == 2\n    state = json.loads(stub._state_path.read_text())\n    assert state[\"last_stopped_reason\"] == \"limit reached\"\n    assert len(state[\"seen_urls\"]) == 2  # only the 2 consumed, not all 5\n\ndef test_crawl_unlimited_exhausts_all(stub, monkeypatch):\n    urls = [f\"https://x/{i}\" for i in range(3)]\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter(urls))\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: make_article(u))\n    saved = stub.crawl(limit=0)\n    assert len(saved) == 3\n    assert json.loads(stub._state_path.read_text())[\"last_stopped_reason\"] == \"exhausted\"\n\ndef test_crawl_skips_already_seen_urls(stub, monkeypatch):\n    stub._state_path.parent.mkdir(parents=True, exist_ok=True)\n    stub._state_path.write_text(json.dumps({\"seen_urls\": [\"https://x/0\"], \"total_saved\": 1}))\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter([\"https://x/0\", \"https://x/1\"]))\n    calls = []\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: (calls.append(u), make_article(u))[1])\n    stub.crawl(limit=10)\n    assert calls == [\"https://x/1\"]  # x/0 never re-parsed\n\ndef test_crawl_parse_error_is_logged_and_url_retried_next_run(stub, monkeypatch):\n    \"\"\"Gap: distinguishes transient fetch/parse errors (NOT marked seen, retried)\n    from structural non-articles (marked seen, never retried again).\"\"\"\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter([\"https://x/bad\"]))\n    def boom(u):\n        raise RuntimeError(\"network blip\")\n    monkeypatch.setattr(stub, \"parse_article\", boom)\n    saved = stub.crawl(limit=10)\n    assert saved == []\n    state = json.loads(stub._state_path.read_text())\n    assert \"https://x/bad\" not in state.get(\"seen_urls\", [])  # must be retried, not permanently skipped\n    assert \"error fetching https://x/bad\" in stub._log_path.read_text()\n\ndef test_crawl_non_article_page_is_marked_seen_permanently(stub, monkeypatch):\n    monkeypatch.setattr(stub, \"list_article_urls\", lambda: iter([\"https://x/tagpage\"]))\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: None)  # title selector didn't match\n    stub.crawl(limit=10)\n    state = json.loads(stub._state_path.read_text())\n    assert \"https://x/tagpage\" in state[\"seen_urls\"]  # permanently skipped, unlike a fetch error\n\ndef test_crawl_discovery_failure_preserves_prior_saved_state(stub, monkeypatch):\n    \"\"\"Gap: discovery-level exception (e.g. sitemap fetch fails mid-walk) must not\n    lose articles already saved earlier in the SAME run, and must not raise.\"\"\"\n    def failing_urls():\n        yield \"https://x/ok\"\n        raise ConnectionError(\"network cut\")\n    monkeypatch.setattr(stub, \"list_article_urls\", failing_urls)\n    monkeypatch.setattr(stub, \"parse_article\", lambda u: make_article(u))\n    saved = stub.crawl(limit=10)  # must NOT raise\n    assert len(saved) == 1\n    state = json.loads(stub._state_path.read_text())\n    assert state[\"last_stopped_reason\"].startswith(\"error:\")\n    assert state[\"total_saved\"] == 1\n\ndef test_append_article_writes_valid_jsonl_line(stub):\n    stub._append_article(make_article(\"https://x/1\"))\n    line = stub._data_path.read_text().splitlines()[0]\n    assert json.loads(line)[\"url\"] == \"https://x/1\"\n\ndef test_load_state_missing_file_returns_defaults(stub):\n    assert stub._load_state() == {\"seen_urls\": [], \"total_saved\": 0}\n```\n\n**Missing error-handling test — corrupted state file.** `_load_state` (base.py:138-141) does `json.loads(...)` with no try/except. A truncated/corrupt `state/*.json` (e.g. from a crash during a non-atomic edit, or manual tampering) currently crashes the whole run instead of degrading gracefully. Add a test that documents current behavior and drives a decision on whether to harden it:\n\n```python\ndef test_load_state_corrupt_json_currently_raises(stub):\n    stub._state_path.parent.mkdir(parents=True, exist_ok=True)\n    stub._state_path.write_text(\"{not valid json\")\n    with pytest.raises(json.JSONDecodeError):\n        stub._load_state()\n```\n\n**Missing test — `fetch()` dispatch (base.py:162-165).** Trivial but untested branch: `needs_stealth=True` → `StealthyFetcher.fetch`, else `Fetcher.get`.\n\n```python\ndef test_fetch_uses_stealthy_fetcher_when_flagged(monkeypatch):\n    class StealthSrc(NewsSource):\n        source_name = \"s\"; selectors = SiteSelectors(title=\"h1\", body=\"p\"); needs_stealth = True\n    with patch(\"base.StealthyFetcher.fetch\") as stealthy, patch(\"base.Fetcher.get\") as plain:\n        StealthSrc().fetch(\"https://x\")\n        stealthy.assert_called_once_with(\"https://x\")\n        plain.assert_not_called()\n\ndef test_list_article_urls_raises_without_sitemap_or_override():\n    class NoSitemapSrc(NewsSource):\n        source_name = \"n\"; selectors = SiteSelectors(title=\"h1\", body=\"p\")\n    with pytest.raises(NotImplementedError):\n        list(NoSitemapSrc().list_article_urls())\n```\n\n---\n\n### 4. `providers.py` — custom per-provider logic\n\nMost of the 11 providers are pure declarative `SiteSelectors` configs (low test value beyond a structural smoke test — see §5). Three providers have real logic and zero tests:\n\n**`MadagascarTribune._is_article_link` (providers.py:72-80)** — pure function, ideal for exhaustive parametrization:\n\n```python\nfrom providers import MadagascarTribune\n\n@pytest.mark.parametrize(\"href,expected\", [\n    (\"mon-article.html\", True),\n    (None, False),\n    (\"mon-article\", False),                      # no .html\n    (\"rubrique-.html\", False),                    # category convention excluded\n    (\"https://other.com/a.html\", False),          # absolute/external excluded\n    (\"/mon-article.html\", False),                 # absolute path excluded\n    (\"_Jean-Dupont,1234.html\", False),             # author/keyword page excluded\n])\ndef test_is_article_link(href, expected):\n    assert MadagascarTribune._is_article_link(href) is expected\n```\n\n**`MadagascarTribune._discover_categories` (providers.py:62-70)** — regex-extract + dedupe + sort-by-int; homepage fetch failure → `[]`.\n\n```python\ndef test_discover_categories_dedupes_and_sorts_numerically(monkeypatch):\n    fake_home = MagicMock(html_content='<a href=\"spip.php?rubrique10\">x</a><a href=\"spip.php?rubrique2\">y</a><a href=\"spip.php?rubrique2\">dup</a>')\n    with patch(\"providers.Fetcher.get\", return_value=fake_home):\n        cats = MadagascarTribune()._discover_categories()\n    assert cats == [\n        \"https://madagascar-tribune.com/spip.php?rubrique2\",\n        \"https://madagascar-tribune.com/spip.php?rubrique10\",  # numeric sort, not lexical\n    ]\n\ndef test_discover_categories_returns_empty_on_fetch_failure():\n    with patch(\"providers.Fetcher.get\", side_effect=ConnectionError):\n        assert MadagascarTribune()._discover_categories() == []\n```\n\n**`MadagascarTribune.list_article_urls` (providers.py:82-111)** — pagination loop: stops when a page yields zero new article links, stops on fetch exception, follows the first-fetch redirect (`page.url` reassignment). No test covers the \"0 links on page → break to next category\" boundary, or the redirect-URL propagation into subsequent `?debut_articles=` pagination requests.\n\n**`FreeNews.list_article_urls` (providers.py:173-191)** — API pagination: HTTP 400 → clean stop (end of pages); other `HTTPError` codes → re-raise; empty `posts` list → stop; page increments correctly.\n\n```python\nimport urllib.error\nfrom providers import FreeNews\n\ndef test_freenews_stops_on_400_past_last_page(monkeypatch):\n    def fake_urlopen(req, timeout):\n        raise urllib.error.HTTPError(req.full_url, 400, \"bad\", {}, None)\n    with patch(\"providers.urllib.request.urlopen\", side_effect=fake_urlopen):\n        assert list(FreeNews().list_article_urls()) == []\n\ndef test_freenews_reraises_non_400_http_errors(monkeypatch):\n    def fake_urlopen(req, timeout):\n        raise urllib.error.HTTPError(req.full_url, 500, \"err\", {}, None)\n    with patch(\"providers.urllib.request.urlopen\", side_effect=fake_urlopen):\n        with pytest.raises(urllib.error.HTTPError):\n            list(FreeNews().list_article_urls())\n\ndef test_freenews_paginates_until_empty_page(monkeypatch):\n    pages = {1: [{\"link\": \"https://a\"}], 2: [{\"link\": \"https://b\"}], 3: []}\n    def fake_urlopen(req, timeout):\n        page_num = int(req.full_url.split(\"page=\")[1].split(\"&\")[0]) if \"page=\" in req.full_url else 1\n        resp = MagicMock(); resp.read.return_value = json.dumps(pages.get(page_num, [])).encode()\n        resp.__enter__.return_value = resp\n        return resp\n    with patch(\"providers.urllib.request.urlopen\", side_effect=fake_urlopen):\n        assert list(FreeNews().list_article_urls()) == [\"https://a\", \"https://b\"]\n```\n\n**`Moov.list_article_urls` (providers.py:212-236)** — BFS frontier: dedup via `queued` set, filters non-`/article/` links, continues past a page that fails to fetch during frontier expansion (still yields the URL itself before attempting expansion — note the `yield url` happens *before* the `try/except Fetcher.get`, so a page that 404s is still yielded and handed to `parse_article`, which will then fail there and get logged/retried by `crawl()`. Worth a test asserting this ordering explicitly, since it's easy to accidentally \"fix\" into a regression).\n\n```python\ndef test_moov_bfs_dedupes_and_yields_before_expansion_failure(monkeypatch):\n    home = MagicMock()\n    home.css.return_value = [MagicMock(attrib={\"href\": \"/article/1\"})]\n    page1 = MagicMock()\n    page1.css.return_value = [MagicMock(attrib={\"href\": \"/article/1\"}),  # dup, ignored\n                               MagicMock(attrib={\"href\": \"/other/2\"})]   # not /article/, ignored\n    with patch(\"providers.Fetcher.get\", side_effect=[home, ConnectionError()]):\n        urls = list(Moov().list_article_urls())\n    assert urls == [\"https://new.moov.mg/article/1\"]  # yielded even though its own expansion fetch fails\n```\n\n---\n\n### 5. Missing integration/structural tests\n\n**Provider registry sanity (providers.py:279-291)** — nothing currently asserts the registry is internally consistent. Cheap, high-value, catches copy-paste config mistakes immediately:\n\n```python\nfrom providers import PROVIDERS\n\n@pytest.mark.parametrize(\"name,cls\", PROVIDERS.items())\ndef test_provider_dict_key_matches_source_name(name, cls):\n    assert cls.source_name == name\n\n@pytest.mark.parametrize(\"name,cls\", PROVIDERS.items())\ndef test_provider_has_required_selectors(name, cls):\n    assert cls.selectors.title\n    assert cls.selectors.body\n\ndef test_provider_source_names_are_unique():\n    names = [cls.source_name for cls in PROVIDERS.values()]\n    assert len(names) == len(set(names))\n\n@pytest.mark.parametrize(\"name,cls\", PROVIDERS.items())\ndef test_provider_declares_sitemap_or_overrides_list_article_urls(name, cls):\n    has_sitemap = cls.sitemap_url is not None\n    overrides = cls.list_article_urls is not NewsSource.list_article_urls\n    assert has_sitemap or overrides, f\"{name}: no sitemap_url and no custom list_article_urls override\"\n```\n\n**`main.py` — zero coverage.** No test verifies argparse wiring, the `\"all\"` expansion, `--limit` plumbing, or the `on_save` print callback.\n\n```python\n# tests/test_main.py\nimport sys\nfrom unittest.mock import patch, MagicMock\nimport main as main_module\n\ndef test_main_crawls_single_provider_with_limit(monkeypatch, capsys):\n    fake_source = MagicMock()\n    fake_source.crawl.return_value = []\n    fake_source._data_path = \"d\"; fake_source._state_path = \"s\"; fake_source._log_path = \"l\"\n    fake_cls = MagicMock(return_value=fake_source)\n    monkeypatch.setattr(main_module, \"PROVIDERS\", {\"newsmada\": fake_cls})\n    monkeypatch.setattr(sys, \"argv\", [\"main.py\", \"newsmada\", \"--limit\", \"5\"])\n    main_module.main()\n    fake_source.crawl.assert_called_once()\n    assert fake_source.crawl.call_args.kwargs[\"limit\"] == 5\n\ndef test_main_all_iterates_every_provider(monkeypatch, capsys):\n    sources = {n: MagicMock(crawl=MagicMock(return_value=[])) for n in (\"a\", \"b\")}\n    for s in sources.values():\n        s._data_path = s._state_path = s._log_path = \"x\"\n    monkeypatch.setattr(main_module, \"PROVIDERS\", {n: MagicMock(return_value=s) for n, s in sources.items()})\n    monkeypatch.setattr(sys, \"argv\", [\"main.py\", \"all\"])\n    main_module.main()\n    for s in sources.values():\n        s.crawl.assert_called_once()\n\ndef test_main_rejects_unknown_provider(monkeypatch):\n    monkeypatch.setattr(sys, \"argv\", [\"main.py\", \"not-a-real-provider\"])\n    with pytest.raises(SystemExit):\n        main_module.main()\n\ndef test_on_save_callback_prints_title_and_date(monkeypatch, capsys):\n    from models import Article\n    fake_source = MagicMock()\n    def fake_crawl(limit, on_save):\n        on_save(Article(url=\"u\", title=\"Hello\", body=\"b\", author=None,\n                         published_date=\"2024-01-01\", category=None, source=\"x\", scraped_at=\"t\"))\n        return []\n    fake_source.crawl.side_effect = fake_crawl\n    fake_source._data_path = fake_source._state_path = fake_source._log_path = \"x\"\n    monkeypatch.setattr(main_module, \"PROVIDERS\", {\"x\": MagicMock(return_value=fake_source)})\n    monkeypatch.setattr(sys, \"argv\", [\"main.py\", \"x\"])\n    main_module.main()\n    assert \"'Hello'\" in capsys.readouterr().out\n```\n\n**`models.py` — one real edge case worth a test:** `Article.images` uses `field(default_factory=list)`, correctly avoiding the classic mutable-default-argument bug. Worth a regression test precisely because it'd be easy for someone to \"simplify\" it to `images: list[str] = []` later and silently reintroduce shared-list state:\n\n```python\nfrom models import Article\n\ndef test_article_images_default_is_not_shared_between_instances():\n    a1 = Article(url=\"u1\", title=\"t\", body=\"b\", author=None, published_date=None,\n                 category=None, source=\"s\", scraped_at=\"ts\")\n    a2 = Article(url=\"u2\", title=\"t\", body=\"b\", author=None, published_date=None,\n                 category=None, source=\"s\", scraped_at=\"ts\")\n    a1.images.append(\"https://x/img.jpg\")\n    assert a2.images == []\n```\n\n---\n\n### Summary / priority order\n\n| Priority | Area | Why |\n|---|---|---|\n| 1 | `NewsSource.crawl()` state/resume/error semantics (§3) | Most complex logic, silent-data-loss risk, zero coverage |\n| 2 | `parse_french_date` / `parse_numeric_date` (§1) | Pure functions, cheap to test, has an unhandled `ValueError` gap |\n| 3 | `discover_sitemap_urls` + `_fetch_xml` (§1) | Subtle namespace/gzip/newline handling, easy to regress |\n| 4 | `NewsSource.parse_article` / `_extract_images` (§2) | Largest branch count, needs a scrapling-shaped fake `page` fixture |\n| 5 | `MadagascarTribune`, `FreeNews`, `Moov` custom crawlers (§4) | Only providers with real logic; rest are declarative config |\n| 6 | Provider registry + `main.py` (§5) | Cheap structural tests, catch config typos immediately |\n\nSuggested layout per project convention (`CLAUDE.md`: tests go in `/tests`, not root): `apps/crawler/tests/test_base.py`, `test_providers.py`, `test_main.py`, `test_models.py`, plus a `conftest.py` for the shared `FakeSource`/`make_page` fixtures.\n\nI haven't written any of these files — this is the gap analysis you asked for. Let me know if you'd like me to actually implement the test suite (starting with §3, the highest-value gap).\n",
