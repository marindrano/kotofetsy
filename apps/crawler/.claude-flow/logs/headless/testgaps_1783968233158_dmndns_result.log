ce([\"a\"], {\"a\": None})  # parse_article returns None\n        src.crawl(limit=10)\n        state = src._load_state()\n        assert \"a\" in state[\"seen_urls\"]\n        assert state.get(\"total_saved\", 0) == 0\n\n    def test_limit_zero_is_unlimited(self, isolated_dirs):\n        urls = [f\"u{i}\" for i in range(5)]\n        src = FakeSource(urls, {u: make_article(u) for u in urls})\n        saved = src.crawl(limit=0)\n        assert len(saved) == 5\n\n    def test_limit_reached_sets_stopped_reason(self, isolated_dirs):\n        urls = [f\"u{i}\" for i in range(5)]\n        src = FakeSource(urls, {u: make_article(u) for u in urls})\n        src.crawl(limit=2)\n        assert src._load_state()[\"last_stopped_reason\"] == \"limit reached\"\n\n    def test_exhausted_sets_stopped_reason(self, isolated_dirs):\n        src = FakeSource([], {})\n        src.crawl(limit=10)\n        assert src._load_state()[\"last_stopped_reason\"] == \"exhausted\"\n\n    def test_discovery_error_is_caught_not_raised(self, isolated_dirs):\n        src = FakeSource([], discovery_error=ConnectionError(\"network down\"))\n        saved = src.crawl(limit=10)  # must not raise\n        assert saved == []\n        assert \"error\" in src._load_state()[\"last_stopped_reason\"]\n\n    def test_on_save_called_only_for_saved_articles(self, isolated_dirs):\n        calls = []\n        src = FakeSource([\"a\", \"b\"], {\"a\": make_article(\"a\"), \"b\": None})\n        src.crawl(limit=10, on_save=calls.append)\n        assert [a.url for a in calls] == [\"a\"]\n\n\nclass TestParseArticle:\n    def test_missing_title_returns_none(self, isolated_dirs):\n        ...  # mock self.fetch() page.css(title).first -> None\n\n    def test_embed_url_skips_about_blank_iframe_falls_back_to_video(self, isolated_dirs):\n        ...\n\n    def test_published_date_attr_vs_formatted_text_branches(self, isolated_dirs):\n        ...\n\n\nclass TestExtractImages:\n    def test_dedupes_cover_and_body_images(self):\n        ...\n\n    def test_prefers_data_src_over_src(self):\n        ...\n\n    def test_skips_data_uri_images(self):\n        ...\n```\n\n---\n\n",
