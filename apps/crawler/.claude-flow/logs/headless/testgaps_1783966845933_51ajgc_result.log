        "content": "Untested. Recursive sitemap-index walking, namespace-stripped `loc` extraction, and the specific edge case called out in the comment: nested `<image:loc>` must NOT be picked up.\n\n```python\nfrom unittest.mock import patch\nfrom base import discover_sitemap_urls\n\nclass TestDiscoverSitemapUrls:\n    @patch(\"base._fetch_xml\")\n    def test_flat_urlset(self, mock_fetch):\n        mock_fetch.return_value = \"\"\"<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n            <url><loc>http://example.com/a</loc></url>\n            <url><loc>http://example.com/b</loc></url>\n        </urlset>\"\"\"\n        assert list(discover_sitemap_urls(\"http://example.com/sitemap.xml\")) == [\n            \"http://example.com/a\", \"http://example.com/b\"\n        ]\n\n    @patch(\"base._fetch_xml\")\n    def test_sitemap_index_recurses(self, mock_fetch):\n        index_xml = \"\"\"<sitemapindex xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n            <sitemap><loc>http://example.com/sub1.xml</loc></sitemap>\n        </sitemapindex>\"\"\"\n        leaf_xml = \"\"\"<urlset><url><loc>http://example.com/article-1</loc></url></urlset>\"\"\"\n        mock_fetch.side_effect = [index_xml, leaf_xml]\n        assert list(discover_sitemap_urls(\"http://example.com/index.xml\")) == [\n            \"http://example.com/article-1\"\n        ]\n\n    @patch(\"base._fetch_xml\")\n    def test_ignores_nested_image_loc(self, mock_fetch):\n        # image:loc localname-matches \"loc\" one level deeper — must not be yielded\n        mock_fetch.return_value = \"\"\"<urlset xmlns:image=\"http://example.com/image\">\n            <url>\n                <loc>http://example.com/article-1</loc>\n                <image:image><image:loc>http://example.com/photo.jpg</image:loc></image:image>\n            </url>\n        </urlset>\"\"\"\n        assert list(discover_sitemap_urls(\"http://example.com/sitemap.xml\")) == [\n            \"http://example.com/article-1\"\n        ]\n\n    @patch(\"base._fetch_xml\")\n    def test_is_lazy_stops_after_enough_pulled(self, mock_fetch):\n        # generator: caller stops pulling once satisfied — sub-sitemaps beyond that\n        # should never be fetched. Verify _fetch_xml call count.\n        index_xml = \"\"\"<sitemapindex>\n            <sitemap><loc>http://example.com/sub1.xml</loc></sitemap>\n            <sitemap><loc>http://example.com/sub2.xml</loc></sitemap>\n        </sitemapindex>\"\"\"\n        leaf_xml = \"\"\"<urlset><url><loc>http://example.com/a1</loc></url></urlset>\"\"\"\n        mock_fetch.side_effect = [index_xml, leaf_xml]\n        gen = discover_sitemap_urls(\"http://example.com/index.xml\")\n        next(gen)  # only pull one\n        assert mock_fetch.call_count == 2  # index + sub1 only, sub2 never fetched\n\n    @patch(\"base._fetch_xml\")\n    def test_malformed_xml_raises(self, mock_fetch):\n        mock_fetch.return_value = \"<not><valid\"\n        with pytest.raises(ET.ParseError):\n            list(discover_sitemap_urls(\"http://example.com/sitemap.xml\"))\n```\nThe laziness test directly exercises the behavior the docstring claims (\"we only fetch as many sitemap sub-files as actually needed\") — currently unverified by anything.\n\n---\n\n",
