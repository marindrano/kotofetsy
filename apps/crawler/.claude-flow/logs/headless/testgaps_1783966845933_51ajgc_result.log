        "content": "Untested — dedup, `data-src` preference over `src`, `data:` URI exclusion, relative→absolute resolution, cover-image-first ordering.\n\n```python\nclass TestExtractImages:\n    def test_cover_image_first(self, source_cls):\n        page = FakePage({\"article img, .entry-content img, .td-post-content img, .post-content img, .vcex-post-content img, figure img\": [\n            FakeElement(attrib={\"src\": \"http://example.com/body.jpg\"})\n        ]})\n        images = source_cls()._extract_images(page, \"http://example.com/a\", \"http://example.com/cover.jpg\")\n        assert images[0] == \"http://example.com/cover.jpg\"\n\n    def test_data_src_preferred_over_src(self, source_cls):\n        selector = source_cls._IMG_CONTAINERS\n        page = FakePage({selector: [FakeElement(attrib={\"src\": \"placeholder.gif\", \"data-src\": \"real.jpg\"})]})\n        images = source_cls()._extract_images(page, \"http://example.com/a\", None)\n        assert images == [\"http://example.com/real.jpg\"]\n\n    def test_data_uri_excluded(self, source_cls):\n        selector = source_cls._IMG_CONTAINERS\n        page = FakePage({selector: [FakeElement(attrib={\"src\": \"data:image/png;base64,AAAA\"})]})\n        images = source_cls()._extract_images(page, \"http://example.com/a\", None)\n        assert images == []\n\n    def test_dedup_across_cover_and_body(self, source_cls):\n        selector = source_cls._IMG_CONTAINERS\n        page = FakePage({selector: [FakeElement(attrib={\"src\": \"http://example.com/dup.jpg\"})]})\n        images = source_cls()._extract_images(page, \"http://example.com/a\", \"http://example.com/dup.jpg\")\n        assert images == [\"http://example.com/dup.jpg\"]\n\n    def test_relative_url_resolved_against_article_url(self, source_cls):\n        selector = source_cls._IMG_CONTAINERS\n        page = FakePage({selector: [FakeElement(attrib={\"src\": \"/img/a.jpg\"})]})\n        images = source_cls()._extract_images(page, \"http://example.com/articles/a\", None)\n        assert images == [\"http://example.com/img/a.jpg\"]\n```\n\n",
