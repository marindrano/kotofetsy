        "code": "class TestCrawl:\n    def _source_with(self, source_cls, urls, parse_results, monkeypatch):\n        src = source_cls()\n        monkeypatch.setattr(src, \"list_article_urls\", lambda: iter(urls))\n        def fake_parse(url):\n            result = parse_results[url]\n            if isinstance(result, Exception):\n                raise result\n            return result\n\n        monkeypatch.setattr(src, \"parse_article\", fake_parse)\n        return src\n\n    def _article(self, url):\n        return Article(url=url, title=\"T\", body=\"B\", author=None, published_date=None,\n                        category=None, source=\"fake-provider\", scraped_at=\"2020-01-01T00:00:00\")\n\n    def test_skips_already_seen_urls(self, source_cls, monkeypatch):\n        src = source_cls()\n        src._save_state({\"seen_urls\": [\"http://a\"], \"total_saved\": 1})\n        monkeypatch.setattr(src, \"list_article_urls\", lambda: iter([\"http://a\", \"http://b\"]))\n        monkeypatch.setattr(src, \"parse_article\", lambda url: self._article(url))\n        saved = src.crawl(limit=10)\n        assert [a.url for a in saved] == [\"http://b\"]\n\n    def test_parse_exception_skips_and_does_not_mark_seen(self, source_cls, monkeypatch):\n        src = self._source_with(source_cls, [\"http://a\"], {\"http://a\": RuntimeError(\"boom\")}, monkeypatch)\n        saved = src.crawl(limit=10)\n        assert saved == []\n        assert src._load_state()[\"seen_urls\"] == []  # retried next run\n\n    def test_none_article_marks_seen_but_not_saved(self, source_cls, monkeypatch):\n        src = self._source_with(source_cls, [\"http://a\"], {\"http://a\": None}, monkeypatch)\n        saved = src.crawl(limit=10)\n        assert saved == []\n        assert src._load_state()[\"seen_urls\"] == [\"http://a\"]  # never retried\n\n    def test_limit_zero_is_unlimited(self, source_cls, monkeypatch):\n        urls = [f\"http://a{i}\" for i in range(5)]\n        src = self._source_with(source_cls, urls, {u: self._article(u) for u in urls}, monkeypatch)\n        saved = src.crawl(limit=0)\n        assert len(saved) == 5\n\n    def test_stops_exactly_at_limit(self, source_cls, monkeypatch):\n        urls = [f\"http://a{i}\" for i in range(5)]\n        src = self._source_with(source_cls, urls, {u: self._article(u) for u in urls}, monkeypatch)\n        saved = src.crawl(limit=2)\n        assert len(saved) == 2\n        assert src._load_state()[\"last_stopped_reason\"] == \"limit reached\"\n\n    def test_exhausted_reason_when_fewer_than_limit(self, source_cls, monkeypatch):\n        urls = [\"http://a\"]\n        src = self._source_with(source_cls, urls, {\"http://a\": self._article(\"http://a\")}, monkeypatch)\n        src.crawl(limit=10)\n        assert src._load_state()[\"last_stopped_reason\"] == \"exhausted\"\n\n    def test_discovery_failure_reraises_and_saves_reason(self, source_cls, monkeypatch):\n        src = source_cls()\n        def failing_urls():\n            raise ConnectionError(\"network down\")\n            yield  # pragma: no cover\n        monkeypatch.setattr(src, \"list_article_urls\", failing_urls)\n        with pytest.raises(ConnectionError):\n            src.crawl(limit=10)\n        assert \"error\" in src._load_state()[\"last_stopped_reason\"]\n\n    def test_on_save_called_once_per_saved_article(self, source_cls, monkeypatch):\n        calls = []\n        src = self._source_with(source_cls, [\"http://a\"], {\"http://a\": self._article(\"http://a\")}, monkeypatch)\n        src.crawl(limit=10, on_save=calls.append)\n        assert len(calls) == 1\n\n    def test_total_saved_accumulates_across_runs(self, source_cls, monkeypatch):\n        src = self._source_with(source_cls, [\"http://a\"], {\"http://a\": self._article(\"http://a\")}, monkeypatch)\n        src.crawl(limit=10)\n        assert src._load_state()[\"total_saved\"] == 1"
