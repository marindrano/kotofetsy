        "code": "class TestMoovListArticleUrls:\n    @patch(\"providers.Fetcher.get\")\n    def test_bfs_dedup_and_filters_non_article_links(self, mock_get):\n        link_article = MagicMock(); link_article.attrib = {\"href\": \"/article/1\"}\n        link_other = MagicMock(); link_other.attrib = {\"href\": \"/other/page\"}\n        home = MagicMock(css=lambda s: [link_article, link_other])\n        article_page = MagicMock(css=lambda s: [])  # no further links\n        mock_get.side_effect = [home, article_page]\n        urls = list(Moov().list_article_urls())\n        assert urls == [\"https://new.moov.mg/article/1\"]\n\n    @patch(\"providers.Fetcher.get\")\n    def test_fetch_failure_during_expansion_does_not_crash(self, mock_get):\n        link = MagicMock(); link.attrib = {\"href\": \"/article/1\"}\n        home = MagicMock(css=lambda s: [link])\n        mock_get.side_effect = [home, ConnectionError(\"down\")]\n        urls = list(Moov().list_article_urls())\n        assert urls == [\"https://new.moov.mg/article/1\"]  # yielded before the failed expansion fetch\n\n    @patch(\"providers.Fetcher.get\")\n    def test_duplicate_article_link_not_requeued(self, mock_get):\n        link1 = MagicMock(); link1.attrib = {\"href\": \"/article/1\"}\n        link_dup = MagicMock(); link_dup.attrib = {\"href\": \"/article/1\"}\n        home = MagicMock(css=lambda s: [link1, link_dup])\n        mock_get.side_effect = [home]  # only one dequeue expected -> one more fetch call\n        urls = list(Moov().list_article_urls())\n        assert urls.count(\"https://new.moov.mg/article/1\") == 1"
