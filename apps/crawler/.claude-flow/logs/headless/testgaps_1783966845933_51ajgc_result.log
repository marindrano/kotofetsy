        "code": "class FakeElement:\n    def __init__(self, text=\"\", attrib=None):\n        self._text = text\n        self.attrib = attrib or {}\n    def get_all_text(self, strip=True):\n        return self._text.strip() if strip else self._text\n\nclass FakeQuery(list):\n    @property\n    def first(self):\n        return self[0] if self else None\n\nclass FakePage:\n    def __init__(self, elements: dict):\n        self._elements = elements  # selector -> list[FakeElement]\n    def css(self, selector):\n        return FakeQuery(self._elements.get(selector, []))\n\nclass TestParseArticle:\n    def _source(self, source_cls, page):\n        src = source_cls()\n        src.fetch = lambda url: page\n        return src\n\n    def test_missing_title_returns_none(self, source_cls):\n        page = FakePage({})  # no title element\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article is None\n\n    def test_full_article_parsed(self, source_cls):\n        page = FakePage({\n            \"h1\": [FakeElement(\"My Title\")],\n            \"p\": [FakeElement(\"Para one.\"), FakeElement(\"Para two.\")],\n            \"meta[property='og:image']\": [FakeElement(attrib={\"content\": \"http://img/cover.jpg\"})],\n        })\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.title == \"My Title\"\n        assert article.body == \"Para one.\\n\\nPara two.\"\n        assert article.cover_image == \"http://img/cover.jpg\"\n\n    def test_empty_paragraphs_excluded_from_body(self, source_cls):\n        page = FakePage({\"h1\": [FakeElement(\"T\")], \"p\": [FakeElement(\"  \"), FakeElement(\"Real text\")]})\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.body == \"Real text\"\n\n    def test_published_date_from_attr(self, source_cls):\n        source_cls.selectors = SiteSelectors(\n            title=\"h1\", body=\"p\", published_date=\"time\", published_date_attr=\"datetime\"\n        )\n        page = FakePage({\n            \"h1\": [FakeElement(\"T\")],\n            \"time\": [FakeElement(attrib={\"datetime\": \"2020-01-01\"})],\n        })\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.published_date == \"2020-01-01\"\n\n    def test_published_date_french_format(self, source_cls):\n        source_cls.selectors = SiteSelectors(\n            title=\"h1\", body=\"p\", published_date=\".date\", published_date_format=\"french\"\n        )\n        page = FakePage({\"h1\": [FakeElement(\"T\")], \".date\": [FakeElement(\"22 juin 2019\")]})\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.published_date == \"2019-06-22\"\n\n    def test_embed_url_prefers_iframe_over_video(self, source_cls):\n        page = FakePage({\n            \"h1\": [FakeElement(\"T\")],\n            \"iframe\": [FakeElement(attrib={\"src\": \"http://embed/video\"})],\n            \"video source\": [FakeElement(attrib={\"src\": \"http://embed/fallback.mp4\"})],\n        })\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.embed_url == \"http://embed/video\"\n\n    def test_embed_url_skips_about_blank_iframe(self, source_cls):\n        page = FakePage({\n            \"h1\": [FakeElement(\"T\")],\n            \"iframe\": [FakeElement(attrib={\"src\": \"about:blank\"})],\n            \"video source\": [FakeElement(attrib={\"src\": \"http://embed/fallback.mp4\"})],\n        })\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.embed_url == \"http://embed/fallback.mp4\"\n\n    def test_no_author_selector_yields_none(self, source_cls):\n        page = FakePage({\"h1\": [FakeElement(\"T\")]})\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.author is None\n\n    def test_author_selector_present_but_element_missing(self, source_cls):\n        source_cls.selectors = SiteSelectors(title=\"h1\", body=\"p\", author=\".byline\")\n        page = FakePage({\"h1\": [FakeElement(\"T\")]})  # .byline not in page\n        article = self._source(source_cls, page).parse_article(\"http://example.com/a\")\n        assert article.author is None"
